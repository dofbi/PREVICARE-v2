        <div class="oe-card-footer">
          <span class="oe-card-loc">Dakar</span>
          <span class="oe-card-cta">Postuler →</span>
        </div>
      </div>

    </div>

    <!-- BLOC ACCÈS RESTREINT -->
    <div class="oe-gate">
      <p class="oe-kicker" style="color:var(--gold-2)">— Accès Silver & Gold requis</p>
      <h2 class="oe-gate-h2">Débloquez les<br/><em>40+ offres</em> disponibles</h2>
