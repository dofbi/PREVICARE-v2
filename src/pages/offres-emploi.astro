---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Offres d'emploi — Previcare Emploi" description="Tableau de bord emploi premium : offres vérifiées au Sénégal par secteur. Accès Silver et Gold.">

<style>
  /* ── HERO SKYLINE ────────────────────────────────────────────── */
  .oe-hero {
    background: var(--ink);
    color: var(--paper);
    padding: 130px 40px 0;
    position: relative;
    overflow: hidden;
  }
  .oe-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 50% 0%, rgba(201,169,97,.1) 0%, transparent 55%),
      radial-gradient(ellipse at 80% 80%, rgba(201,169,97,.05) 0%, transparent 40%);
  }
  .oe-hero-inner {
    position: relative;
    z-index: 2;
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
  }
  .oe-kicker {
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 7px;
    text-transform: uppercase;
    color: var(--gold-2);
    margin-bottom: 32px;
  }
  .oe-h1 {
    font-family: var(--display);
    font-style: italic;
    font-size: clamp(56px, 9vw, 110px);
    line-height: .95;
    margin: 0 0 28px;
  }
  .oe-h1 em { font-style: normal; color: var(--gold-2); }
  .oe-sub {
    font-family: var(--serif);
    font-style: italic;
    font-size: 19px;
    color: rgba(246,244,238,.65);
    margin: 0 auto 56px;
    max-width: 560px;
    line-height: 1.65;
  }

  /* Skyline SVG */
  .oe-skyline {
    position: relative;
    z-index: 2;
    margin-top: 20px;
  }
  .oe-skyline svg {
    width: 100%;
    max-width: 1320px;
    display: block;
    margin: 0 auto;
    opacity: .18;
  }

  /* ── BARRE DE FILTRE ─────────────────────────────────────────── */
  .oe-filter {
    background: #fff;
    border-bottom: 1px solid var(--rule);
    padding: 0 40px;
    position: sticky;
    top: 64px;
    z-index: 20;
  }
  .oe-filter-inner {
    max-width: 1320px;
    margin: 0 auto;
    display: flex;
    gap: 0;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .oe-filter-inner::-webkit-scrollbar { display: none; }
  .oe-filter-btn {
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--ink-3);
    padding: 18px 20px;
    border-bottom: 2px solid transparent;
    background: none;
    border-top: none;
    border-left: none;
    border-right: none;
    cursor: pointer;
    white-space: nowrap;
    transition: .2s;
    text-decoration: none;
    display: inline-block;
  }
  .oe-filter-btn:hover,
  .oe-filter-btn.active { color: var(--ink); border-bottom-color: var(--gold); }

  /* ── GRILLE OFFRES ───────────────────────────────────────────── */
  .oe-main {
    padding: 80px 40px;
    background: var(--paper);
  }
  .oe-main-inner { max-width: 1320px; margin: 0 auto; }
  .oe-section-title {
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--ink-4);
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--rule);
  }
  .oe-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    background: var(--rule);
    border: 1px solid var(--rule);
    margin-bottom: 80px;
  }

  /* Carte offre */
  .oe-card {
    background: var(--paper);
    padding: 36px 32px;
    display: flex;
    flex-direction: column;
    transition: background .2s;
    position: relative;
  }
  .oe-card:hover { background: #fff; }
  .oe-card-premium {
    position: absolute;
    top: 20px;
    right: 20px;
    font-family: var(--sans);
    font-size: 8px;
    letter-spacing: 3px;
    text-transform: uppercase;
    background: var(--gold);
    color: var(--ink);
    padding: 3px 10px;
    border-radius: 99px;
    font-weight: 700;
  }
  .oe-card-logo {
    width: 44px;
    height: 44px;
    background: var(--ink);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    flex-shrink: 0;
  }
  .oe-card-logo span {
    font-family: var(--display);
    font-style: italic;
    font-size: 18px;
    color: var(--gold);
  }
  .oe-card-company {
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--ink-4);
    margin-bottom: 8px;
  }
  .oe-card-title {
    font-family: var(--display);
    font-style: italic;
    font-size: 24px;
    color: var(--ink);
    margin: 0 0 16px;
    line-height: 1.15;
  }
  .oe-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 20px;
  }
  .oe-tag {
    font-family: var(--sans);
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 4px 10px;
    border: 1px solid var(--rule);
    border-radius: 99px;
    color: var(--ink-3);
  }
  .oe-tag-sector { border-color: var(--gold); color: var(--gold-3); }
  .oe-card-desc {
    font-size: 13px;
    color: var(--ink-3);
    line-height: 1.65;
    margin: 0 0 24px;
    flex: 1;
  }
  .oe-card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 20px;
    border-top: 1px solid var(--rule);
  }
  .oe-card-loc {
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 1px;
    color: var(--ink-4);
  }
  .oe-card-cta {
    font-family: var(--sans);
    font-size: 9px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--ink);
    border-bottom: 1px solid var(--gold);
    padding-bottom: 2px;
    text-decoration: none;
    transition: color .2s;
  }
  .oe-card-cta:hover { color: var(--gold-3); }

  /* Carte floue (accès restreint) */
  .oe-card-blur {
    filter: blur(4px);
    pointer-events: none;
    user-select: none;
    opacity: .6;
  }

  /* ── BLOC ACCÈS RESTREINT ────────────────────────────────────── */
  .oe-gate {
    background: var(--ink);
    color: var(--paper);
    border: 1px solid rgba(201,169,97,.2);
    padding: 72px 48px;
    text-align: center;
    margin-bottom: 80px;
  }
  .oe-gate-h2 {
    font-family: var(--display);
    font-style: italic;
    font-size: clamp(32px, 4vw, 48px);
    margin: 16px 0 20px;
  }
  .oe-gate-h2 em { font-style: normal; color: var(--gold-2); }
  .oe-gate-p { font-size: 16px; color: rgba(246,244,238,.72); max-width: 480px; margin: 0 auto 40px; line-height: 1.7; }

  /* ── SECTEURS ────────────────────────────────────────────────── */
  .oe-sectors {
    margin-top: 40px;
  }
  .oe-sectors-title {
    font-family: var(--display);
    font-style: italic;
    font-size: clamp(28px, 3.5vw, 40px);
    margin: 0 0 40px;
  }
  .oe-sectors-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 2px;
    background: var(--rule);
    border: 1px solid var(--rule);
  }
  .oe-sector {
    background: var(--paper);
    padding: 28px 20px;
    text-align: center;
    transition: background .2s;
  }
  .oe-sector:hover { background: #fff; }
  .oe-sector-name {
    font-family: var(--display);
    font-style: italic;
    font-size: 18px;
    color: var(--ink);
    margin: 0 0 6px;
  }
  .oe-sector-count {
    font-family: var(--sans);
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gold-3);
  }

  @media (max-width: 960px) {
    .oe-grid { grid-template-columns: 1fr; }
    .oe-sectors-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 600px) {
    .oe-sectors-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

