---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Coffre-fort documentaire — Previcare Emploi" description="Archivage numérique sécurisé AES-256 pour vos documents RH. Conforme aux lois sénégalaises 2008-08 et 2008-12.">

<style>
  /* ── HERO ────────────────────────────────────────────────────── */
  .cf-hero {
    background: var(--ink);
    color: var(--paper);
    padding: 130px 40px 100px;
    position: relative;
    overflow: hidden;
  }
  .cf-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 30% 50%, rgba(201,169,97,.1) 0%, transparent 55%),
      radial-gradient(ellipse at 75% 20%, rgba(201,169,97,.07) 0%, transparent 40%);
  }
  .cf-hero-inner {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }
  .cf-kicker {
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 7px;
    text-transform: uppercase;
    color: var(--gold-2);
    margin-bottom: 32px;
  }
  .cf-h1 {
    font-family: var(--display);
    font-style: italic;
    font-size: clamp(52px, 7vw, 88px);
    line-height: .95;
    margin: 0 0 28px;
  }
  .cf-h1 em { font-style: normal; color: var(--gold-2); }
  .cf-sub {
    font-family: var(--serif);
    font-style: italic;
    font-size: 19px;
    color: rgba(246,244,238,.72);
    line-height: 1.65;
    margin: 0 0 40px;
  }
  .cf-hero-btns { display: flex; gap: 14px; flex-wrap: wrap; }

  /* Safe SVG animé */
  .cf-safe-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .cf-safe { position: relative; }
  .cf-safe svg { width: min(400px, 90%); }
  .cf-safe-glow {
    position: absolute;
    inset: -30px;
    background: radial-gradient(circle at 50% 50%, rgba(201,169,97,.18) 0%, transparent 65%);
    animation: cfPulse 3s ease-in-out infinite;
  }
  @keyframes cfPulse {
    0%, 100% { opacity: .6; transform: scale(.95); }
    50%       { opacity: 1;  transform: scale(1.05); }
  }
  .cf-dial-anim { animation: cfDial 8s ease-in-out infinite; transform-origin: 200px 200px; }
  @keyframes cfDial {
    0%   { transform: rotate(0deg);   }
    20%  { transform: rotate(120deg);  }
    35%  { transform: rotate(120deg);  }
    55%  { transform: rotate(-80deg);  }
    70%  { transform: rotate(-80deg);  }
    90%  { transform: rotate(40deg);   }
    100% { transform: rotate(40deg);   }
  }

  /* ── SPECS GRID ──────────────────────────────────────────────── */
  .cf-specs {
    padding: 100px 40px;
    background: var(--paper);
  }
  .cf-specs-inner { max-width: 1320px; margin: 0 auto; }
  .cf-specs-head {
    text-align: center;
    margin-bottom: 64px;
  }
  .cf-specs-h2 {
    font-family: var(--display);
    font-style: italic;
    font-size: clamp(36px, 4.5vw, 56px);
    margin: 16px 0 20px;
  }
  .cf-specs-h2 em { font-style: normal; color: var(--gold-3); }
  .cf-specs-p { font-size: 17px; color: var(--ink-3); max-width: 560px; margin: 0 auto; line-height: 1.7; }

  .cf-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    background: var(--rule);
    border: 1px solid var(--rule);
  }
  .cf-spec {
    background: var(--paper);
    padding: 48px 36px;
    transition: background .25s;
    display: flex;
    flex-direction: column;
  }
  .cf-spec:hover { background: #fff; }
  .cf-spec svg {
    width: 48px;
    height: 48px;
    color: var(--gold-3);
    margin-bottom: 24px;
    flex-shrink: 0;
  }
  .cf-spec-t {
    font-family: var(--display);
    font-style: italic;
    font-size: 26px;
    color: var(--ink);
    margin: 0 0 12px;
    line-height: 1.15;
  }
  .cf-spec-d { font-size: 14px; color: var(--ink-3); line-height: 1.7; margin: 0; flex: 1; }

  /* ── CONFORMITÉ ──────────────────────────────────────────────── */
  .cf-conform {
    padding: 80px 40px;
    background: #fff;
  }
  .cf-conform-inner {
    max-width: 1000px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }
  .cf-conform-h2 {
    font-family: var(--display);
    font-style: italic;
    font-size: clamp(32px, 4vw, 48px);
    margin: 16px 0 20px;
    line-height: 1.1;
  }
  .cf-conform-h2 em { font-style: normal; color: var(--gold-3); }
  .cf-conform-p { font-size: 15px; color: var(--ink-3); line-height: 1.75; margin: 0 0 32px; }
  .cf-conform-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .cf-conform-list li {
    padding: 14px 0;
    border-bottom: 1px solid var(--rule);
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-family: var(--sans);
    font-size: 13px;
    color: var(--ink-3);
    line-height: 1.5;
  }
  .cf-conform-list li:last-child { border-bottom: none; }
  .cf-badge {
    font-family: var(--sans);
    font-size: 9px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    padding: 5px 12px;
    border: 1px solid var(--gold);
    border-radius: 99px;
    color: var(--gold-3);
    margin-bottom: 8px;
    display: inline-block;
  }

  /* ── CTA ─────────────────────────────────────────────────────── */
  .cf-cta {
    padding: 100px 40px;
    background: var(--ink);
    text-align: center;
    color: var(--paper);
  }
  .cf-cta-h2 {
    font-family: var(--display);
    font-style: italic;
    font-size: clamp(36px, 5vw, 60px);
    margin: 16px 0 20px;
  }
  .cf-cta-h2 em { font-style: normal; color: var(--gold-2); }
  .cf-cta-p { font-size: 17px; color: rgba(246,244,238,.72); max-width: 520px; margin: 0 auto 40px; line-height: 1.7; }

  @media (max-width: 900px) {
    .cf-hero-inner, .cf-conform-inner { grid-template-columns: 1fr; }
    .cf-safe-wrap { padding-top: 40px; }
    .cf-grid { grid-template-columns: 1fr; }
  }
</style>

<!-- HERO -->
<section class="cf-hero">
  <div class="cf-hero-inner">
    <div>
      <p class="cf-kicker">— Outil III · Archivage sécurisé</p>
      <h1 class="cf-h1">Le <em>coffre-fort</em><br/>documentaire</h1>
      <p class="cf-sub">Vos documents RH archivés, chiffrés et accessibles pour toujours. Conformité totale aux lois sénégalaises sur la protection des données.</p>
      <div class="cf-hero-btns">
        <a href="/connexion" class="btn btn-gold">Accéder à mon coffre</a>
        <a href="/formules"  class="btn btn-ghost" style="border-color:rgba(246,244,238,.3);color:var(--paper)">Voir les formules</a>
      </div>
    </div>
    <div class="cf-safe-wrap">
      <div class="cf-safe">
        <div class="cf-safe-glow"></div>
        <svg viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg">
          <!-- Corps du coffre -->
          <rect x="60" y="80" width="280" height="240" rx="8" fill="#142849" stroke="#C9A961" stroke-width="2"/>
          <!-- Porte -->
          <rect x="80" y="100" width="180" height="200" rx="4" fill="#0B1D3A" stroke="#C9A961" stroke-width="1.5"/>
          <!-- Cercle du cadran -->
          <circle cx="170" cy="200" r="55" fill="#142849" stroke="#C9A961" stroke-width="2"/>
          <circle cx="170" cy="200" r="42" fill="#0B1D3A" stroke="rgba(201,169,97,.4)" stroke-width="1"/>
          <!-- Aiguille du cadran -->
          <g class="cf-dial-anim">
            <line x1="170" y1="200" x2="170" y2="160" stroke="#C9A961" stroke-width="2.5" stroke-linecap="round"/>
          </g>
          <!-- Centre cadran -->
          <circle cx="170" cy="200" r="5" fill="#C9A961"/>
          <!-- Graduations cadran -->
          <g stroke="#C9A961" stroke-width="1" opacity=".4">
            <line x1="170" y1="148" x2="170" y2="158"/>
            <line x1="222" y1="200" x2="212" y2="200"/>
            <line x1="170" y1="252" x2="170" y2="242"/>
            <line x1="118" y1="200" x2="128" y2="200"/>
            <line x1="207" y1="163" x2="200" y2="170"/>
            <line x1="207" y1="237" x2="200" y2="230"/>
            <line x1="133" y1="163" x2="140" y2="170"/>
            <line x1="133" y1="237" x2="140" y2="230"/>
          </g>
          <!-- Poignée -->
          <rect x="270" y="185" width="28" height="30" rx="4" fill="#142849" stroke="#C9A961" stroke-width="1.5"/>
          <circle cx="284" cy="200" r="5" fill="none" stroke="#C9A961" stroke-width="1.5"/>
          <!-- Charnières -->
          <rect x="72" y="115" width="12" height="20" rx="2" fill="#C9A961" opacity=".6"/>
          <rect x="72" y="265" width="12" height="20" rx="2" fill="#C9A961" opacity=".6"/>
          <!-- Petits coffres superposés à droite -->
          <rect x="278" y="110" width="48" height="36" rx="3" fill="#1A3055" stroke="#C9A961" stroke-width="1" opacity=".7"/>
          <rect x="278" y="158" width="48" height="36" rx="3" fill="#1A3055" stroke="#C9A961" stroke-width="1" opacity=".6"/>
          <rect x="278" y="206" width="48" height="36" rx="3" fill="#1A3055" stroke="#C9A961" stroke-width="1" opacity=".5"/>
          <!-- Icône cadenas dans chaque petit coffre -->
          <path d="M296 122 a6 6 0 0 1 12 0v4h-12z" fill="none" stroke="#C9A961" stroke-width="1" opacity=".8"/>
          <rect x="293" y="126" width="18" height="12" rx="2" fill="#C9A961" opacity=".4"/>
        </svg>
      </div>
    </div>
  </div>
</section>

<!-- SPECS GRID -->
<section class="cf-specs">
  <div class="cf-specs-inner">
    <div class="cf-specs-head">
      <p class="cf-kicker">— Spécifications techniques</p>
      <h2 class="cf-specs-h2">Un coffre <em>sans compromis</em></h2>
      <p class="cf-specs-p">Chaque décision d'architecture a été prise pour garantir la sécurité, la durabilité et la conformité de vos documents.</p>
    </div>
    <div class="cf-grid">
      <div class="cf-spec">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round">
          <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/>
        </svg>
        <h3 class="cf-spec-t">Chiffrement AES-256</h3>
        <p class="cf-spec-d">Chiffrement de niveau militaire en transit (TLS 1.3) et au repos. Vos clés de chiffrement vous appartiennent — aucun accès tiers, même Previcare.</p>
      </div>
      <div class="cf-spec">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          <path d="M9 12l2 2 4-4"/>
        </svg>
        <h3 class="cf-spec-t">Conservation légale</h3>
        <p class="cf-spec-d">Archivage décennal garanti conforme au délai légal de prescription en droit du travail sénégalais. Vos documents restent accessibles même après rupture d'abonnement.</p>
      </div>
      <div class="cf-spec">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round">
          <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/>
          <circle cx="12" cy="12" r="3"/>
        </svg>
        <h3 class="cf-spec-t">Accès multi-appareils</h3>
        <p class="cf-spec-d">Consultez vos documents depuis smartphone, tablette ou ordinateur. Interface adaptative, chargement en moins de 2 secondes, même sur connexion 3G.</p>
      </div>
      <div class="cf-spec">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round">
          <path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8"/>
          <polyline points="16 6 12 2 8 6"/>
          <line x1="12" y1="2" x2="12" y2="15"/>
        </svg>
        <h3 class="cf-spec-t">Partage sécurisé</h3>
        <p class="cf-spec-d">Partagez un document par lien temporisé avec votre employeur, votre avocat ou votre délégué. Durée d'accès configurable, révocation en un clic.</p>
      </div>
      <div class="cf-spec">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round">
          <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="16" y1="13" x2="8" y2="13"/>
          <line x1="16" y1="17" x2="8" y2="17"/>
          <polyline points="10 9 9 9 8 9"/>
        </svg>
        <h3 class="cf-spec-t">Formats acceptés</h3>
        <p class="cf-spec-d">PDF, JPEG, PNG, DOCX, XLSX — tous les formats courants de documents RH. Conversion automatique en PDF pour la consultation en ligne sans logiciel.</p>
      </div>
      <div class="cf-spec">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round">
          <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
        </svg>
        <h3 class="cf-spec-t">Suivi d'activité</h3>
        <p class="cf-spec-d">Journal d'accès complet : qui a consulté, téléchargé ou partagé un document, et quand. Notification immédiate en cas d'accès depuis un nouveau terminal.</p>
      </div>
    </div>
  </div>
</section>

<!-- CONFORMITÉ -->
<section class="cf-conform">
  <div class="cf-conform-inner">
    <div>
      <span class="cf-badge">Conformité légale</span>
      <h2 class="cf-conform-h2">Conforme aux lois<br/><em>sénégalaises</em></h2>
      <p class="cf-conform-p">Le coffre-fort documentaire Previcare Emploi a été conçu en conformité avec les textes sénégalais et les standards internationaux applicables.</p>
      <ul class="cf-conform-list">
        <li><span style="color:var(--gold-3);flex-shrink:0">→</span><span><strong>Loi n° 2008-12</strong> sur la protection des données personnelles au Sénégal</span></li>
        <li><span style="color:var(--gold-3);flex-shrink:0">→</span><span><strong>Loi n° 2008-08</strong> sur les transactions électroniques</span></li>
        <li><span style="color:var(--gold-3);flex-shrink:0">→</span><span><strong>Code du Travail art. 87</strong> — délais de conservation des documents RH</span></li>
        <li><span style="color:var(--gold-3);flex-shrink:0">→</span><span><strong>RGPD</strong> pour les utilisateurs résidents en zone CEDEAO/UE</span></li>
        <li><span style="color:var(--gold-3);flex-shrink:0">→</span><span><strong>Autorité de protection des données</strong> (CDP Sénégal) — déclaration conforme</span></li>
      </ul>
    </div>
    <div>
      <svg viewBox="0 0 340 340" width="100%" style="max-width:340px;display:block;margin:0 auto">
        <defs>
          <radialGradient id="cfShieldGrad" cx=".5" cy=".3" r=".7">
            <stop offset="0" stop-color="#C9A961" stop-opacity=".15"/>
            <stop offset="1" stop-color="#0B1D3A" stop-opacity="0"/>
          </radialGradient>
        </defs>
        <circle cx="170" cy="170" r="155" fill="url(#cfShieldGrad)"/>
        <circle cx="170" cy="170" r="153" fill="none" stroke="#C9A961" stroke-width=".6" opacity=".3"/>
        <circle cx="170" cy="170" r="110" fill="none" stroke="#C9A961" stroke-width=".4" stroke-dasharray="3,6" opacity=".25"/>
        <path d="M170 50 L250 88 L250 190 Q250 252 170 290 Q90 252 90 190 L90 88 Z"
              fill="#0B1D3A" stroke="#C9A961" stroke-width="2" stroke-linejoin="round"/>
        <path d="M170 70 L236 102 L236 188 Q236 240 170 272 Q104 240 104 188 L104 102 Z"
              fill="#142849" stroke="rgba(201,169,97,.4)" stroke-width="1"/>
        <path d="M145 170 l15 15 30-30" stroke="#C9A961" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        <text x="170" y="220" text-anchor="middle" font-family="Inter" font-size="9" letter-spacing="3" fill="#C9A961" opacity=".8">AES-256</text>
      </svg>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cf-cta">
  <p class="cf-kicker" style="color:var(--gold-2)">— Ouvrir votre coffre</p>
  <h2 class="cf-cta-h2">Vos documents,<br/>pour <em>toujours</em></h2>
  <p class="cf-cta-p">La formule Basique inclut 5 documents. Passez en Silver ou Gold pour un archivage illimité et le partage sécurisé.</p>
  <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap">
    <a href="/connexion" class="btn btn-gold">Accéder à mon coffre</a>
    <a href="/formules"  class="btn btn-ghost" style="border-color:rgba(246,244,238,.3);color:var(--paper)">Voir les formules</a>
  </div>
</section>

</Layout>
