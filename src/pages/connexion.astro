---
import Layout from '../layouts/Layout.astro';
import { actions } from 'astro:actions';

const { user } = Astro.locals;

// Récupérer le paramètre redirect pour après connexion
const redirectParam = Astro.url.searchParams.get('redirect');

// Si l'utilisateur est déjà connecté, le rediriger vers sa page (ou le redirect demandé)
if (user) {
  if (redirectParam) {
    return Astro.redirect(redirectParam);
  }
  
  const userRole = user.user_metadata?.role;

  // Redirect based on user role
  if (userRole === 'employee') {
    return Astro.redirect(user.user_metadata?.is_expatriate ? '/espace-expatries' : '/espace-employes');
  } else if (userRole === 'employer') {
    return Astro.redirect('/espace-employeurs');
  } else if (userRole === 'delegate') {
    return Astro.redirect('/espace-delegues');
  }

  return Astro.redirect('/');
}

const result = Astro.getActionResult(actions.auth.signIn);

// Redirection après connexion réussie selon le rôle
if (result && !result.error && result.data?.success) {
  // Prioriser le redirect de l'URL si présent, sinon utiliser celui de la réponse
  const finalRedirectUrl = redirectParam || result.data.redirectUrl;
  return Astro.redirect(finalRedirectUrl);
}

// Construire l'URL d'inscription avec le redirect
const inscriptionUrl = redirectParam ? `/inscription?redirect=${encodeURIComponent(redirectParam)}` : '/inscription';
---

<Layout title="Connexion — Previcare Emploi" description="Accédez à votre espace personnel Previcare Emploi.">

<style>
  .cx-page {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: var(--paper);
  }

  /* ── Panneau gauche illustration ─────────────────────────────── */
  .cx-left {
    background: var(--ink);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 60px 64px;
    position: relative;
    overflow: hidden;
  }
  .cx-left::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 30% 40%, rgba(201,169,97,.1) 0%, transparent 55%);
  }
  .cx-left-inner { position: relative; z-index: 2; }
  .cx-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 5px;
    text-transform: uppercase;
    color: var(--paper);
    text-decoration: none;
    margin-bottom: 80px;
  }
  .cx-logo-dot { width: 6px; height: 6px; background: var(--gold); border-radius: 50%; flex-shrink: 0; }
  .cx-left-quote {
    font-family: var(--display);
    font-style: italic;
    font-size: clamp(28px, 3vw, 42px);
    color: var(--paper);
    line-height: 1.25;
    margin: 0 0 20px;
  }
  .cx-left-quote em { font-style: normal; color: var(--gold-2); }
  .cx-left-source {
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: rgba(246,244,238,.4);
  }
  .cx-left-features {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .cx-left-features li {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--sans);
    font-size: 12px;
    color: rgba(246,244,238,.65);
    padding: 10px 0;
    border-bottom: 1px solid rgba(201,169,97,.1);
  }
  .cx-left-features li:last-child { border-bottom: none; }
  .cx-left-features li::before {
    content: "";
    width: 6px;
    height: 6px;
    background: var(--gold);
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* ── Panneau droit formulaire ────────────────────────────────── */
  .cx-right {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 60px 48px;
  }
  .cx-form-wrap { width: 100%; max-width: 420px; }

  .cx-kicker {
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 5px;
    text-transform: uppercase;
    color: var(--gold-3);
    margin-bottom: 20px;
  }
  .cx-h1 {
    font-family: var(--display);
    font-style: italic;
    font-size: 44px;
    color: var(--ink);
    margin: 0 0 8px;
    line-height: 1.05;
  }
  .cx-sub {
    font-family: var(--serif);
    font-style: italic;
    font-size: 16px;
    color: var(--ink-3);
    margin: 0 0 36px;
    line-height: 1.5;
  }

  /* Tabs */
  .cx-tabs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: var(--rule);
    border: 1px solid var(--rule);
    border-radius: 99px;
    padding: 3px;
    margin-bottom: 36px;
    gap: 3px;
  }
  .cx-tab {
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    padding: 10px;
    border-radius: 99px;
    text-align: center;
    color: var(--ink-3);
    text-decoration: none;
    transition: .2s;
    background: none;
    border: none;
    cursor: pointer;
  }
  .cx-tab.active {
    background: var(--ink);
    color: var(--paper);
  }
  .cx-tab:not(.active):hover { color: var(--ink); }

  /* Erreur */
  .cx-error {
    background: #fef2f2;
    border: 1px solid #fecaca;
    border-left: 3px solid #ef4444;
    padding: 14px 16px;
    border-radius: 4px;
    margin-bottom: 20px;
    font-family: var(--sans);
    font-size: 13px;
    color: #991b1b;
  }

  /* Champs */
  .cx-field { margin-bottom: 20px; }
  .cx-label {
    display: block;
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-bottom: 8px;
  }
  .cx-input-wrap { position: relative; }
  .cx-input-icon {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--ink-4);
    pointer-events: none;
  }
  .cx-input-icon svg { width: 16px; height: 16px; }
  .cx-input {
    width: 100%;
    height: 48px;
    padding: 0 14px 0 42px;
    border: 1px solid var(--rule);
    background: #fff;
    font-family: var(--sans);
    font-size: 14px;
    color: var(--ink);
    outline: none;
    transition: border-color .2s;
    border-radius: 4px;
    box-sizing: border-box;
  }
  .cx-input:focus { border-color: var(--gold); box-shadow: 0 0 0 3px rgba(201,169,97,.08); }
  .cx-input-btn {
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    cursor: pointer;
    color: var(--ink-4);
    padding: 2px;
    display: flex;
    align-items: center;
  }
  .cx-input-btn svg { width: 16px; height: 16px; }

  .cx-forgotlink {
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gold-3);
    text-decoration: none;
    display: block;
    text-align: right;
    margin-bottom: 28px;
    transition: color .2s;
  }
  .cx-forgotlink:hover { color: var(--gold); }

  /* Bouton submit */
  .cx-submit {
    width: 100%;
    height: 48px;
    background: var(--ink);
    color: var(--paper);
    border: 1px solid var(--ink);
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 4px;
    text-transform: uppercase;
    cursor: pointer;
    border-radius: 4px;
    transition: background .25s, border-color .25s;
    margin-bottom: 28px;
  }
  .cx-submit:hover { background: var(--gold-3); border-color: var(--gold-3); }

  /* Pied de formulaire */
  .cx-footer {
    font-family: var(--sans);
    font-size: 12px;
    color: var(--ink-4);
    text-align: center;
    line-height: 1.6;
  }
  .cx-footer a { color: var(--gold-3); transition: color .2s; }
  .cx-footer a:hover { color: var(--gold); }
  .cx-divider { height: 1px; background: var(--rule); margin: 24px 0; }

  @media (max-width: 800px) {
    .cx-page { grid-template-columns: 1fr; }
    .cx-left { display: none; }
    .cx-right { padding: 48px 24px; }
  }
</style>

<div class="cx-page">

  <!-- Panneau gauche -->
  <div class="cx-left">
    <div class="cx-left-inner">
      <a href="/" class="cx-logo">
        <span class="cx-logo-dot"></span>
        Previcare Emploi
      </a>
      <blockquote>
        <p class="cx-left-quote">
          Votre <em>dossier RH</em>,<br/>
          toujours à portée.
        </p>
        <footer class="cx-left-source">— Plateforme RH 360° · Sénégal</footer>
      </blockquote>
    </div>
    <div class="cx-left-inner">
      <ul class="cx-left-features">
        <li>Coffre-fort documentaire sécurisé AES-256</li>
        <li>Setlou — conseiller juridique IA 24 h/24</li>
        <li>Xalima — rédaction de courriers guidée</li>
        <li>Offres d'emploi vérifiées au Sénégal</li>
        <li>Consultations avec juristes certifiés</li>
      </ul>
    </div>
  </div>

  <!-- Panneau droit -->
  <div class="cx-right">
    <div class="cx-form-wrap">
      <p class="cx-kicker">— Espace personnel</p>
      <h1 class="cx-h1">Connexion</h1>
      <p class="cx-sub">Accédez à votre espace Previcare Emploi.</p>

      <!-- Tabs -->
      <div class="cx-tabs">
        <button class="cx-tab active" aria-current="page">Connexion</button>
        <a href={inscriptionUrl} class="cx-tab">Inscription</a>
      </div>

      <!-- Erreur -->
      {(result?.error || (result?.data && !result.data.success)) && (
        <div class="cx-error">
          {result?.error?.message || result?.data?.message || "Une erreur s'est produite lors de la connexion."}
        </div>
      )}

      <form method="POST" action={actions.auth.signIn}>
        <div class="cx-field">
          <label for="email" class="cx-label">Adresse e-mail</label>
          <div class="cx-input-wrap">
            <span class="cx-input-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </span>
            <input type="email" id="email" name="email" placeholder="nom@exemple.com" class="cx-input" required />
          </div>
        </div>

        <div class="cx-field">
          <label for="password" class="cx-label">Mot de passe</label>
          <div class="cx-input-wrap">
            <span class="cx-input-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/>
              </svg>
            </span>
            <input type="password" id="password" name="password" placeholder="••••••••" class="cx-input" required style="padding-right: 46px" />
            <button type="button" class="cx-input-btn toggle-password" data-target="password">
              <svg class="eye-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
              </svg>
              <svg class="eye-closed hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                <path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24"/>
                <line x1="1" y1="1" x2="23" y2="23"/>
              </svg>
            </button>
          </div>
        </div>

        <a href="/reset-password" class="cx-forgotlink">Mot de passe oublié ?</a>

        <button type="submit" class="cx-submit">Se connecter →</button>
      </form>

      <div class="cx-divider"></div>
      <div class="cx-footer">
        Pas encore de compte ?&nbsp;
        <a href={inscriptionUrl}>Créer un compte</a>
        &ensp;·&ensp;
        <a href="/formules">Voir les formules</a>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const toggleButtons = document.querySelectorAll('.toggle-password');
    toggleButtons.forEach(button => {
      button.addEventListener('click', function(this: HTMLElement) {
        const targetId = this.getAttribute('data-target');
        const eyeOpen = this.querySelector('.eye-open');
        const eyeClosed = this.querySelector('.eye-closed');
        const targetInput = document.getElementById(targetId!) as HTMLInputElement;
        if (targetInput?.type === 'password') {
          targetInput.type = 'text';
          eyeOpen?.classList.add('hidden');
          eyeClosed?.classList.remove('hidden');
        } else {
          targetInput.type = 'password';
          eyeOpen?.classList.remove('hidden');
          eyeClosed?.classList.add('hidden');
        }
      });
    });
  });
</script>

</Layout>
