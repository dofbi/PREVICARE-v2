
---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import DashboardShell from '../../components/DashboardShell.astro';
import DashboardBanner from '../../components/dashboard/DashboardBanner.astro';
import DashboardHero from '../../components/dashboard/DashboardHero.astro';
import DashboardStats from '../../components/dashboard/DashboardStats.astro';
import QuickAccessGrid from '../../components/dashboard/QuickAccessGrid.astro';
import { notificationService } from '../../lib/notificationService.ts';
import { createClient } from '../../lib/supabase';
import { SubscriptionService } from '../../lib/subscriptionService';
import { requireRole } from '../../lib/guards';

const guard = await requireRole(Astro, 'employee');
if (guard) return guard;

const { user } = Astro.locals;
const supabase = createClient({ request: Astro.request, cookies: Astro.cookies });
const subscriptionService = new SubscriptionService(supabase);
const activeSubscription = await subscriptionService.getUserSubscription(user.id);
const hasActiveSubscription = !!(activeSubscription && activeSubscription.status === 'active');
const planLabel = activeSubscription?.plan.display_name ?? null;

const { data: documentsData } = await supabase
  .from('user_documents')
  .select('id')
  .eq('owner_id', user.id);
const documentCount = documentsData?.length ?? 0;

await notificationService.loadNotifications();
const recentNotifications = notificationService.getNotifications({ read: false }).slice(0, 3);
const unreadCount = notificationService.getUnreadCount();
---

<DashboardLayout title="Espace Employés - PREVICARE EMPLOI">
  <DashboardShell role="employee">

    <DashboardBanner
      hasSubscription={hasActiveSubscription}
      planLabel={planLabel}
      role="employee"
    />

    <DashboardHero
      title={`Bienvenue, ${user.user_metadata?.first_name} ${user.user_metadata?.last_name}`}
      subtitle="Votre espace personnel PREVICARE EMPLOI"
    />

    <DashboardStats
      stats={[
        {
          label: 'Abonnement',
          value: hasActiveSubscription ? (planLabel ?? 'Actif') : 'Inactif',
          sublabel: hasActiveSubscription ? 'Protection active' : 'Souscription requise',
          icon: 'check',
          color: hasActiveSubscription ? 'green' : 'orange',
        },
        {
          label: 'Documents archivés',
          value: documentCount,
          sublabel: 'Documents sécurisés',
          icon: 'document',
          color: 'secondary',
        },
        {
          label: 'Notifications',
          value: unreadCount,
          sublabel: unreadCount > 0 ? 'Non lues' : 'Tout est à jour',
          icon: 'message',
          color: unreadCount > 0 ? 'orange' : 'green',
        },
      ]}
    />

    <QuickAccessGrid
      items={[
        {
          title: 'Mes Documents',
          description: 'Coffre-fort numérique',
          href: '/espace-employes/documents',
          icon: 'document',
        },
        {
          title: 'Conseil Juridique',
          description: 'Protection juridique',
          href: '/espace-employes/juridique',
          icon: 'shield',
        },
        {
          title: 'Assistance',
          description: 'Support & FAQ',
          href: '/espace-employes/assistance',
          icon: 'support',
        },
        {
          title: 'Mon Abonnement',
          description: 'Contrat & factures',
          href: '/espace-employes/abonnement',
          icon: 'card',
        },
      ]}
    />

    <!-- Widgets Notifications + Ressources -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-5 mb-8">

      <!-- Notifications -->
      <div class="bg-white rounded-xl border" style="border-color:var(--rule)">
        <div class="px-5 py-4 border-b flex items-center justify-between" style="border-color:var(--rule)">
          <div class="flex items-center gap-2">
            <h3 class="text-base font-semibold" style="color:var(--ink)">Notifications</h3>
            {unreadCount > 0 && (
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-semibold" style="background:rgba(201,169,97,.15);color:var(--gold-3)">
                {unreadCount} {unreadCount > 1 ? 'nouvelles' : 'nouvelle'}
              </span>
            )}
          </div>
          <a href="/espace-employes/notifications" class="text-xs font-medium hover:opacity-80 transition-opacity" style="color:var(--gold-3)">
            Voir tout →
          </a>
        </div>
        <div class="divide-y" style="--tw-divide-color:var(--rule)">
          {recentNotifications.length === 0 ? (
            <div class="px-6 py-8 text-center">
              <svg class="mx-auto h-10 w-10 mb-2" style="color:var(--ink-4)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
              </svg>
              <p class="text-sm" style="color:var(--ink-4)">Aucune nouvelle notification</p>
            </div>
          ) : (
            recentNotifications.map((notification) => (
              <div data-key={notification.id} class="px-5 py-3.5 hover:bg-[var(--paper)] transition-colors">
                <div class="flex items-start gap-3">
                  <svg class="h-4 w-4 mt-0.5 flex-shrink-0" style={notification.type === 'urgent' ? 'color:#ef4444' : notification.type === 'success' ? 'color:#16a34a' : 'color:var(--gold-3)'} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    {notification.type === 'urgent'
                      ? <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.664-.833-2.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z" />
                      : notification.type === 'success'
                      ? <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                      : <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    }
                  </svg>
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium" style="color:var(--ink)">{notification.title}</p>
                    <p class="text-sm mt-0.5 leading-relaxed line-clamp-2" style="color:var(--ink-4)">{notification.message}</p>
                    {notification.action_url && (
                      <a href={notification.action_url} class="text-sm font-medium mt-1 inline-block hover:opacity-80" style="color:var(--gold-3)">
                        {notification.action_label || 'Voir plus'} →
                      </a>
                    )}
                  </div>
                </div>
              </div>
            ))
          )}
        </div>
      </div>

      <!-- Ressources utiles -->
      <div class="bg-white rounded-xl border" style="border-color:var(--rule)">
        <div class="px-5 py-4 border-b flex items-center justify-between" style="border-color:var(--rule)">
          <h3 class="text-base font-semibold" style="color:var(--ink)">Ressources utiles</h3>
          <a href="/espace-employes/assistance" class="text-xs font-medium hover:opacity-80 transition-opacity" style="color:var(--gold-3)">Centre d'aide →</a>
        </div>
        <div class="p-5 space-y-3">
          {[
            { href: '/espace-employes/assistance/faq', title: 'Questions fréquentes (FAQ)', desc: 'Réponses aux questions courantes', icon: 'M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z' },
            { href: '/espace-employes/assistance#guide', title: 'Guide utilisateur', desc: 'Documentation complète', icon: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253' },
            { href: '/espace-employes/assistance#contact', title: 'Contact support', desc: 'Parlez à notre équipe', icon: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z' },
          ].map((item) => (
            <a href={item.href} class="group flex items-center gap-3 p-3.5 rounded-xl border transition-all hover:shadow-sm no-underline" style="border-color:var(--rule)">
              <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0" style="background:rgba(201,169,97,.10)">
                <svg class="h-4 w-4" style="color:var(--gold-3)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d={item.icon} />
                </svg>
              </div>
              <div>
                <p class="text-sm font-medium" style="color:var(--ink)">{item.title}</p>
                <p class="text-sm" style="color:var(--ink-4)">{item.desc}</p>
              </div>
              <svg class="w-4 h-4 ml-auto opacity-0 group-hover:opacity-60 transition-opacity" style="color:var(--gold)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Assistants IA -->
    <div class="mb-8">
      <h2 class="text-xl font-bold mb-1" style="font-family:var(--display);color:var(--ink)">Vos Assistants IA</h2>
      <p class="text-sm mb-5" style="color:var(--ink-4)">Deux assistants spécialisés pour vous accompagner au quotidien</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

        <!-- SETLOU -->
        <a href="/espace-employes/juridique/setlou" class="group bg-white rounded-xl border p-5 flex flex-col transition-all hover:shadow-md no-underline" style="border-color:var(--rule)" onmouseover="this.style.borderColor='var(--rule-gold)'" onmouseout="this.style.borderColor='var(--rule)'">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style="background:var(--ink)">
              <svg class="w-5 h-5" style="color:var(--gold)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-sm" style="color:var(--ink)">SETLOU</h3>
              <span class="text-xs" style="color:var(--ink-4)">Conseiller juridique IA</span>
            </div>
          </div>
          <p class="text-sm flex-1 leading-relaxed" style="color:var(--ink-4)">Expert en droit du travail sénégalais. Posez vos questions sur vos droits, procédures RH et démarches administratives.</p>
          <div class="mt-4 flex items-center gap-1 text-xs font-semibold" style="color:var(--gold-3)">
            Consulter SETLOU
            <svg class="w-3.5 h-3.5 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </a>

        <!-- Xalima -->
        <a href="/espace-employes/juridique/courriers" class="group bg-white rounded-xl border p-5 flex flex-col transition-all hover:shadow-md no-underline" style="border-color:var(--rule)" onmouseover="this.style.borderColor='var(--rule-gold)'" onmouseout="this.style.borderColor='var(--rule)'">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style="background:rgba(201,169,97,.15)">
              <svg class="w-5 h-5" style="color:var(--gold-3)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-sm" style="color:var(--ink)">Xalima</h3>
              <span class="text-xs" style="color:var(--ink-4)">Rédaction de courriers IA</span>
            </div>
          </div>
          <p class="text-sm flex-1 leading-relaxed" style="color:var(--ink-4)">Générateur guidé de courriers professionnels conformes au droit sénégalais. Congé, contestation, réclamation, démission…</p>
          <div class="mt-4 flex items-center gap-1 text-xs font-semibold" style="color:var(--gold-3)">
            Rédiger un courrier
            <svg class="w-3.5 h-3.5 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </a>
      </div>
    </div>

  </DashboardShell>
</DashboardLayout>
