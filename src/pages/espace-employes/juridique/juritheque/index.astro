---
import DashboardLayout from '../../../../layouts/DashboardLayout.astro';

---

<DashboardLayout title="Jurithèque - PREVICARE EMPLOI">
  <div className="bg-blue-50 border-l-4 border-blue-500 p-8">
    <div className="flex">
      <div className="flex-shrink-0">
        <svg className="h-5 w-5 text-blue-400" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
        </svg>
      </div>
      <div className="ml-3">
        <p className="text-lg text-blue-700 font-semibold">Jurithèque déplacée</p>
        <p className="text-blue-600">
          La Jurithèque est maintenant accessible à l'adresse: 
          <a href="/espace-employes/juritheque" className="font-semibold underline">
            /espace-employes/juritheque
          </a>
        </p>
        <a href="/espace-employes/juritheque" className="mt-4 inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-blue-700 bg-blue-100 hover:bg-blue-200">
          Accéder à la Jurithèque
        </a>
      </div>
    </div>
  </div>
</DashboardLayout>
