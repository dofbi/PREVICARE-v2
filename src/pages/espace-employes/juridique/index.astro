---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import DashboardShell from '../../../components/DashboardShell.astro';

const { user } = Astro.locals;

if (!user) {
  return Astro.redirect('/connexion');
}
---

<DashboardLayout title="Conseil Juridique - PREVICARE EMPLOI">
  <DashboardShell role="employee">

    <!-- Breadcrumb -->
    <nav class="flex mb-6" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 text-sm" style="color:var(--ink-4)">
        <li><a href="/espace-employes" class="hover:opacity-80 transition-opacity" style="color:var(--ink-4)">Tableau de bord</a></li>
        <li><span>/</span></li>
        <li class="font-medium" style="color:var(--ink)">Juridique</li>
      </ol>
    </nav>

    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-2xl font-bold" style="font-family:var(--display);color:var(--ink)">Protection Juridique Professionnelle</h1>
      <p class="text-sm mt-1" style="color:var(--ink-4)">Accédez à vos droits et protégez-vous juridiquement dans votre environnement professionnel</p>
    </div>

    <!-- Stats Cards -->
    <div class="grid gap-4 md:grid-cols-3 mb-8">
      <div class="bg-white rounded-xl border p-6" style="border-color:var(--rule)">
        <p class="text-xs font-semibold uppercase tracking-wider mb-2" style="color:var(--ink-4)">Consultations disponibles</p>
        <p class="text-3xl font-bold" style="color:var(--ink)">Illimitées</p>
        <p class="text-xs mt-1" style="color:var(--ink-4)">Conseil juridique bronze</p>
      </div>
      <div class="bg-white rounded-xl border p-6" style="border-color:var(--rule)">
        <p class="text-xs font-semibold uppercase tracking-wider mb-2" style="color:var(--ink-4)">Consultations utilisées</p>
        <p class="text-3xl font-bold" style="color:#15803d">3</p>
        <p class="text-xs mt-1" style="color:var(--ink-4)">Ce mois-ci</p>
      </div>
      <div class="bg-white rounded-xl border p-6" style="border-color:var(--rule)">
        <p class="text-xs font-semibold uppercase tracking-wider mb-2" style="color:var(--ink-4)">Dossiers actifs</p>
        <p class="text-3xl font-bold" style="color:#c2410c">1</p>
        <p class="text-xs mt-1" style="color:var(--ink-4)">En cours de traitement</p>
      </div>
    </div>

    <!-- Services juridiques -->
    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">

      <!-- SETLOU -->
      <a href="/espace-employes/juridique/setlou"
        class="block bg-white rounded-xl border hover:shadow-md transition-shadow p-6"
        style="border-color:var(--rule);border-left:4px solid var(--ink)">
        <div class="flex items-start gap-4">
          <div class="h-10 w-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background:rgba(201,169,97,.12)">
            <svg class="h-5 w-5" style="color:var(--gold-3)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <div>
            <div class="flex items-center gap-2 mb-0.5">
              <h4 class="font-semibold" style="color:var(--ink)">SETLOU</h4>
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium" style="background:rgba(201,169,97,.12);color:var(--gold-3)">
                <span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span>IA disponible
              </span>
            </div>
            <p class="text-xs" style="color:var(--ink-4)">Conseiller juridique IA</p>
          </div>
        </div>
        <p class="text-sm mt-4 leading-relaxed" style="color:var(--ink-4)">Posez vos questions sur le droit du travail sénégalais, vos droits, les procédures RH et les démarches administratives.</p>
        <p class="text-xs font-semibold mt-3" style="color:var(--gold-3)">Consulter SETLOU →</p>
      </a>

      <!-- Xalima -->
      <a href="/espace-employes/juridique/courriers"
        class="block bg-white rounded-xl border hover:shadow-md transition-shadow p-6"
        style="border-color:var(--rule);border-left:4px solid var(--gold)">
        <div class="flex items-start gap-4">
          <div class="h-10 w-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background:rgba(201,169,97,.12)">
            <svg class="h-5 w-5" style="color:var(--gold-3)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
            </svg>
          </div>
          <div>
            <div class="flex items-center gap-2 mb-0.5">
              <h4 class="font-semibold" style="color:var(--ink)">Xalima</h4>
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium" style="background:rgba(201,169,97,.12);color:var(--gold-3)">
                <span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span>IA disponible
              </span>
            </div>
            <p class="text-xs" style="color:var(--ink-4)">Rédaction de courriers IA</p>
          </div>
        </div>
        <p class="text-sm mt-4 leading-relaxed" style="color:var(--ink-4)">Générez des courriers professionnels guidés et conformes au droit sénégalais : congé, contestation, réclamation, démission…</p>
        <p class="text-xs font-semibold mt-3" style="color:var(--gold-3)">Rédiger un courrier →</p>
      </a>

      <!-- Jurithèque -->
      <a href="/espace-employes/juritheque"
        class="block bg-white rounded-xl border hover:shadow-md transition-shadow p-6"
        style="border-color:var(--rule)">
        <div class="flex items-start gap-4">
          <div class="h-10 w-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background:rgba(201,169,97,.12)">
            <svg class="h-5 w-5" style="color:var(--gold-3)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
            </svg>
          </div>
          <div>
            <h4 class="font-semibold" style="color:var(--ink)">Jurithèque</h4>
            <p class="text-xs mt-0.5" style="color:var(--ink-4)">Bibliothèque de textes juridiques sénégalais</p>
          </div>
        </div>
        <p class="text-sm mt-4 leading-relaxed" style="color:var(--ink-4)">Consultez le Code du Travail, les Conventions Collectives et tous les textes de référence du droit sénégalais.</p>
      </a>

      <!-- Consultation juridique -->
      <a href="/espace-employes/juridique/consultation"
        class="block bg-white rounded-xl border hover:shadow-md transition-shadow p-6"
        style="border-color:var(--rule)">
        <div class="flex items-start gap-4">
          <div class="h-10 w-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background:rgba(201,169,97,.12)">
            <svg class="h-5 w-5" style="color:var(--gold-3)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <div>
            <h4 class="font-semibold" style="color:var(--ink)">Consultation juridique</h4>
            <p class="text-xs mt-0.5" style="color:var(--ink-4)">Conseils illimités par téléphone</p>
          </div>
        </div>
        <p class="text-sm mt-4 leading-relaxed" style="color:var(--ink-4)">Obtenez des conseils juridiques personnalisés pour vos problématiques professionnelles.</p>
      </a>

      <!-- Aide à la rédaction -->
      <a href="/espace-employes/juridique/courriers"
        class="block bg-white rounded-xl border hover:shadow-md transition-shadow p-6"
        style="border-color:var(--rule)">
        <div class="flex items-start gap-4">
          <div class="h-10 w-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background:rgba(201,169,97,.12)">
            <svg class="h-5 w-5" style="color:var(--gold-3)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
            </svg>
          </div>
          <div>
            <h4 class="font-semibold" style="color:var(--ink)">Aide à la rédaction</h4>
            <p class="text-xs mt-0.5" style="color:var(--ink-4)">Courriers et documents officiels</p>
          </div>
        </div>
        <p class="text-sm mt-4 leading-relaxed" style="color:var(--ink-4)">Assistance pour rédiger vos courriers de défense et documents administratifs.</p>
      </a>

      <!-- Suivi des dossiers -->
      <div class="bg-white rounded-xl border p-6" style="border-color:var(--rule)">
        <div class="flex items-start gap-4">
          <div class="h-10 w-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background:rgba(201,169,97,.12)">
            <svg class="h-5 w-5" style="color:var(--gold-3)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
            </svg>
          </div>
          <div>
            <h4 class="font-semibold" style="color:var(--ink)">Suivi des dossiers</h4>
            <p class="text-xs mt-0.5" style="color:var(--ink-4)">État de vos demandes</p>
          </div>
        </div>
        <p class="text-sm mt-4 leading-relaxed" style="color:var(--ink-4)">Consultez l'avancement de vos dossiers juridiques en cours.</p>
        <div class="mt-4">
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold" style="background:rgba(201,169,97,.12);color:var(--gold-3)">
            1 dossier en cours
          </span>
        </div>
      </div>

      <!-- Formation juridique -->
      <div class="bg-white rounded-xl border p-6" style="border-color:var(--rule)">
        <div class="flex items-start gap-4">
          <div class="h-10 w-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background:rgba(201,169,97,.12)">
            <svg class="h-5 w-5" style="color:var(--gold-3)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
            </svg>
          </div>
          <div>
            <h4 class="font-semibold" style="color:var(--ink)">Formation juridique</h4>
            <p class="text-xs mt-0.5" style="color:var(--ink-4)">Droits des travailleurs</p>
          </div>
        </div>
        <p class="text-sm mt-4 leading-relaxed" style="color:var(--ink-4)">Sessions d'information sur vos droits et obligations professionnelles.</p>
        <div class="mt-4">
          <button class="text-xs font-semibold" style="color:var(--gold-3)">Voir les sessions →</button>
        </div>
      </div>

      <!-- Veille juridique -->
      <div class="bg-white rounded-xl border p-6" style="border-color:var(--rule)">
        <div class="flex items-start gap-4">
          <div class="h-10 w-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background:rgba(201,169,97,.12)">
            <svg class="h-5 w-5" style="color:var(--gold-3)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <div>
            <h4 class="font-semibold" style="color:var(--ink)">Veille juridique</h4>
            <p class="text-xs mt-0.5" style="color:var(--ink-4)">Actualités du droit du travail</p>
          </div>
        </div>
        <p class="text-sm mt-4 leading-relaxed" style="color:var(--ink-4)">Restez informé des évolutions légales qui vous concernent.</p>
        <div class="mt-4">
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold" style="background:rgba(201,169,97,.12);color:var(--gold-3)">
            3 nouvelles actualités
          </span>
        </div>
      </div>

      <!-- Urgence juridique -->
      <div class="bg-white rounded-xl border p-6" style="border-color:var(--rule)">
        <div class="flex items-start gap-4">
          <div class="h-10 w-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background:rgba(239,68,68,.08)">
            <svg class="h-5 w-5" style="color:#dc2626" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
          </div>
          <div>
            <h4 class="font-semibold" style="color:var(--ink)">Urgence juridique</h4>
            <p class="text-xs mt-0.5" style="color:var(--ink-4)">Assistance immédiate</p>
          </div>
        </div>
        <p class="text-sm mt-4 leading-relaxed" style="color:var(--ink-4)">Contactez notre équipe juridique en cas d'urgence professionnelle.</p>
        <div class="mt-4">
          <button class="inline-flex items-center gap-2 px-3 py-1.5 text-xs font-semibold rounded-lg border" style="border-color:rgba(239,68,68,.30);color:#dc2626;background:rgba(239,68,68,.06)">
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            Appeler maintenant
          </button>
        </div>
      </div>
    </div>

    <!-- Historique récent -->
    <div class="mt-8 bg-white rounded-xl border" style="border-color:var(--rule)">
      <div class="px-6 py-4 border-b" style="border-color:var(--rule)">
        <h3 class="font-semibold" style="color:var(--ink)">Historique récent</h3>
      </div>
      <div class="px-6 py-4">
        <ul class="space-y-5">
          <li class="flex gap-4">
            <div class="h-8 w-8 rounded-full flex items-center justify-center flex-shrink-0" style="background:var(--ink)">
              <svg class="h-4 w-4" style="color:var(--gold)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div class="flex-1 flex justify-between">
              <p class="text-sm" style="color:var(--ink-4)">Consultation juridique sur <span class="font-semibold" style="color:var(--ink)">conflit avec l'employeur</span></p>
              <time class="text-xs whitespace-nowrap" style="color:var(--ink-4)">10 mars</time>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="h-8 w-8 rounded-full flex items-center justify-center flex-shrink-0" style="background:rgba(201,169,97,.12)">
              <svg class="h-4 w-4" style="color:var(--gold-3)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
              </svg>
            </div>
            <div class="flex-1 flex justify-between">
              <p class="text-sm" style="color:var(--ink-4)">Aide rédaction <span class="font-semibold" style="color:var(--ink)">courrier de contestation</span></p>
              <time class="text-xs whitespace-nowrap" style="color:var(--ink-4)">5 mars</time>
            </div>
          </li>
        </ul>
      </div>
    </div>

  </DashboardShell>
</DashboardLayout>
