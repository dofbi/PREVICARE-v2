---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import DashboardShell from '../../../components/DashboardShell.astro';
import { createClient } from '../../../lib/supabase';
import { TicketService } from '../../../lib/ticketService';
import { TICKET_CATEGORIES, TICKET_PRIORITIES, TICKET_STATUSES } from '../../../types/tickets';

const { user } = Astro.locals;

if (!user) {
  return Astro.redirect('/connexion');
}

const supabase = createClient({ request: Astro.request, cookies: Astro.cookies });
const ticketService = new TicketService(supabase);

const tickets = await ticketService.getUserTickets(user.id);
const stats = await ticketService.getTicketStats(user.id);

function formatDate(dateString: string): string {
  return new Date(dateString).toLocaleDateString('fr-FR', {
    day: '2-digit',
    month: 'short',
    year: 'numeric'
  });
}

function timeAgo(dateString: string): string {
  const date = new Date(dateString);
  const now = new Date();
  const diffMs = now.getTime() - date.getTime();
  const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));
  if (diffDays === 0) return "Aujourd'hui";
  if (diffDays === 1) return "Hier";
  if (diffDays < 7) return `Il y a ${diffDays} jours`;
  return formatDate(dateString);
}
---

<DashboardLayout title="Mes Demandes - PREVICARE EMPLOI">
  <DashboardShell role="employee">

    <!-- Breadcrumb -->
    <nav class="flex mb-6" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 text-sm" style="color:var(--ink-4)">
        <li><a href="/espace-employes" class="hover:opacity-80 transition-opacity" style="color:var(--ink-4)">Tableau de bord</a></li>
        <li><span>/</span></li>
        <li><a href="/espace-employes/assistance" class="hover:opacity-80 transition-opacity" style="color:var(--ink-4)">Assistance</a></li>
        <li><span>/</span></li>
        <li class="font-medium" style="color:var(--ink)">Tickets</li>
      </ol>
    </nav>

    <div class="space-y-6">
      <!-- Stats -->
      <div class="grid grid-cols-1 sm:grid-cols-4 gap-4">
        <div class="bg-white rounded-xl border p-4" style="border-color:var(--rule)">
          <div class="flex items-center gap-3">
            <div class="p-2.5 rounded-lg" style="background:rgba(201,169,97,.12)">
              <svg class="h-5 w-5" style="color:var(--gold-3)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
              </svg>
            </div>
            <div>
              <p class="text-xs" style="color:var(--ink-4)">Total</p>
              <p class="text-2xl font-bold" style="color:var(--ink)">{stats.total}</p>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-xl border p-4" style="border-color:var(--rule)">
          <div class="flex items-center gap-3">
            <div class="p-2.5 rounded-lg" style="background:rgba(201,169,97,.12)">
              <svg class="h-5 w-5" style="color:var(--gold-3)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div>
              <p class="text-xs" style="color:var(--ink-4)">Ouverts</p>
              <p class="text-2xl font-bold" style="color:var(--ink)">{stats.open}</p>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-xl border p-4" style="border-color:var(--rule)">
          <div class="flex items-center gap-3">
            <div class="p-2.5 rounded-lg" style="background:rgba(234,179,8,.10)">
              <svg class="h-5 w-5" style="color:#ca8a04" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
            </div>
            <div>
              <p class="text-xs" style="color:var(--ink-4)">En cours</p>
              <p class="text-2xl font-bold" style="color:#ca8a04">{stats.inProgress}</p>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-xl border p-4" style="border-color:var(--rule)">
          <div class="flex items-center gap-3">
            <div class="p-2.5 rounded-lg" style="background:rgba(22,163,74,.10)">
              <svg class="h-5 w-5" style="color:#16a34a" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <div>
              <p class="text-xs" style="color:var(--ink-4)">Résolus</p>
              <p class="text-2xl font-bold" style="color:#16a34a">{stats.resolved}</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Header liste -->
      <div class="flex justify-between items-center">
        <h2 class="font-semibold" style="color:var(--ink)">Vos demandes</h2>
        <a href="/espace-employes/tickets/nouveau"
          class="inline-flex items-center gap-2 px-4 py-2 text-sm font-semibold rounded-lg transition-opacity hover:opacity-90"
          style="background:var(--ink);color:var(--gold)">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
          Nouvelle demande
        </a>
      </div>

      {tickets.length > 0 ? (
        <div class="bg-white rounded-xl border overflow-hidden" style="border-color:var(--rule)">
          <div class="divide-y" style="--tw-divide-color:var(--rule);border-color:var(--rule)">
            {tickets.map((ticket: any) => (
              <a
                href={`/espace-employes/tickets/${ticket.id}`}
                class="block p-4 transition-colors hover:bg-[rgba(11,29,58,.02)]"
              >
                <div class="flex items-start justify-between gap-4">
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 mb-1 flex-wrap">
                      <span class="text-sm" style="color:var(--ink-4)">{ticket.ticket_number}</span>
                      <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${TICKET_CATEGORIES[ticket.category as keyof typeof TICKET_CATEGORIES]?.color || 'bg-gray-100 text-gray-800'}`}>
                        {TICKET_CATEGORIES[ticket.category as keyof typeof TICKET_CATEGORIES]?.icon || ''}
                        {TICKET_CATEGORIES[ticket.category as keyof typeof TICKET_CATEGORIES]?.label || ticket.category}
                      </span>
                      <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${TICKET_STATUSES[ticket.status as keyof typeof TICKET_STATUSES]?.color || 'bg-gray-100 text-gray-800'}`}>
                        {TICKET_STATUSES[ticket.status as keyof typeof TICKET_STATUSES]?.label || ticket.status}
                      </span>
                    </div>
                    <h3 class="text-sm font-semibold truncate" style="color:var(--ink)">{ticket.subject}</h3>
                    <p class="text-sm mt-1 leading-relaxed line-clamp-2" style="color:var(--ink-4)">{ticket.description}</p>
                  </div>
                  <div class="flex-shrink-0 text-right">
                    <p class="text-sm" style="color:var(--ink-4)">{timeAgo(ticket.created_at)}</p>
                    {ticket.priority !== 'normal' && (
                      <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium mt-1 ${TICKET_PRIORITIES[ticket.priority as keyof typeof TICKET_PRIORITIES]?.color || ''}`}>
                        {TICKET_PRIORITIES[ticket.priority as keyof typeof TICKET_PRIORITIES]?.label || ticket.priority}
                      </span>
                    )}
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      ) : (
        <div class="bg-white rounded-xl border p-10 text-center" style="border-color:var(--rule)">
          <div class="mx-auto w-16 h-16 rounded-full flex items-center justify-center mb-4" style="background:rgba(201,169,97,.08)">
            <svg class="h-8 w-8" style="color:var(--gold-3)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
            </svg>
          </div>
          <h3 class="font-semibold mb-2" style="color:var(--ink)">Aucune demande</h3>
          <p class="text-sm mb-6" style="color:var(--ink-4)">Vous n'avez pas encore créé de demande d'assistance.</p>
          <a href="/espace-employes/tickets/nouveau"
            class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold rounded-lg transition-opacity hover:opacity-90"
            style="background:var(--ink);color:var(--gold)">
            Créer une demande
          </a>
        </div>
      )}
    </div>

  </DashboardShell>
</DashboardLayout>
