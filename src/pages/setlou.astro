---
import Layout from '../layouts/Layout.astro';
import { AssistanceChat } from '../components/employee/AssistanceChat';
const { user } = Astro.locals;
---
<Layout title="Setlou — Conseiller juridique IA — Previcare Emploi" description="Setlou maîtrise le droit du travail sénégalais : Code du Travail, conventions collectives, jurisprudence. Réponses claires avec références légales.">

<style>
  /* ── HERO SPLIT ──────────────────────────────────────────────── */
  .sl-hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 80vh;
  }
  .sl-hero-dark {
    background: var(--ink);
    padding: 120px 56px 80px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .sl-hero-dark::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 20% 50%, rgba(201,169,97,.1) 0%, transparent 60%);
  }
  .sl-hero-dark-inner { position: relative; z-index: 2; }
  .sl-kicker {
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 7px;
    text-transform: uppercase;
    color: var(--gold-2);
    margin-bottom: 32px;
  }
  .sl-h1 {
    font-family: var(--display);
    font-style: italic;
    font-size: clamp(64px, 7vw, 96px);
    line-height: .9;
    margin: 0 0 28px;
    color: var(--paper);
  }
  .sl-h1-sub {
    font-family: var(--display);
    font-style: italic;
    font-size: clamp(22px, 2.5vw, 30px);
    color: rgba(246,244,238,.6);
    margin: 0 0 40px;
    line-height: 1.3;
  }
  .sl-avertissement {
    font-family: var(--sans);
    font-size: 11px;
    color: rgba(246,244,238,.45);
    line-height: 1.65;
    margin: 0 0 40px;
    padding: 16px 20px;
    border-left: 2px solid rgba(201,169,97,.3);
    font-style: italic;
  }
  .sl-hero-btns { display: flex; gap: 14px; flex-wrap: wrap; }

  /* Panneau droit lumineux */
  .sl-hero-light {
    background: var(--paper);
    padding: 80px 56px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    border-left: 1px solid var(--rule);
  }
  .sl-sources-title {
    font-family: var(--display);
    font-style: italic;
    font-size: 28px;
    margin: 0 0 32px;
    color: var(--ink);
  }
  .sl-sources { list-style: none; padding: 0; margin: 0; }
  .sl-sources li {
    padding: 14px 0;
    border-bottom: 1px solid var(--rule);
    display: flex;
    align-items: flex-start;
    gap: 16px;
    font-family: var(--sans);
    font-size: 13px;
    color: var(--ink-3);
    line-height: 1.5;
  }
  .sl-sources li:last-child { border-bottom: none; }
  .sl-src-num {
    font-family: var(--display);
    font-style: italic;
    font-size: 20px;
    color: var(--gold-3);
    flex-shrink: 0;
    line-height: 1.2;
  }
  .sl-src-name { color: var(--ink); font-weight: 500; display: block; margin-bottom: 2px; }

  /* ── PROCESSUS ───────────────────────────────────────────────── */
  .sl-process {
    padding: 100px 40px;
    background: #fff;
  }
  .sl-process-inner { max-width: 1200px; margin: 0 auto; }
  .sl-process-head { text-align: center; margin-bottom: 64px; }
  .sl-process-h2 {
    font-family: var(--display);
    font-style: italic;
    font-size: clamp(36px, 4.5vw, 52px);
    margin: 16px 0 0;
  }
  .sl-process-h2 em { font-style: normal; color: var(--gold-3); }

  .sl-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    position: relative;
  }
  .sl-steps::before {
    content: "";
    position: absolute;
    top: 40px;
    left: calc(12.5% + 20px);
    right: calc(12.5% + 20px);
    height: 1px;
    background: linear-gradient(to right, transparent, var(--gold), var(--gold), var(--gold), transparent);
    opacity: .4;
    z-index: 0;
  }
  .sl-step {
    text-align: center;
    padding: 0 24px 40px;
    position: relative;
    z-index: 1;
  }
  .sl-step-num {
    width: 80px;
    height: 80px;
    background: var(--paper);
    border: 1px solid var(--gold);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 24px;
    font-family: var(--display);
    font-style: italic;
    font-size: 32px;
    color: var(--gold-3);
  }
  .sl-step-t {
    font-family: var(--display);
    font-style: italic;
    font-size: 22px;
    color: var(--ink);
    margin: 0 0 12px;
  }
  .sl-step-d { font-size: 13px; color: var(--ink-3); line-height: 1.65; margin: 0; }

  /* ── DOMAINES ────────────────────────────────────────────────── */
  .sl-domains {
    padding: 100px 40px;
    background: var(--ink);
    color: var(--paper);
  }
  .sl-domains-inner { max-width: 1200px; margin: 0 auto; }
  .sl-domains-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 20px;
    margin-bottom: 56px;
  }
  .sl-domains-h2 {
    font-family: var(--display);
    font-style: italic;
    font-size: clamp(36px, 4.5vw, 52px);
    margin: 16px 0 0;
  }
  .sl-domains-h2 em { font-style: normal; color: var(--gold-2); }
  .sl-domains-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
    background: rgba(201,169,97,.08);
    border: 1px solid rgba(201,169,97,.15);
  }
  .sl-domain {
    padding: 36px 28px;
    background: rgba(20,40,73,.6);
    transition: background .25s;
  }
  .sl-domain:hover { background: rgba(20,40,73,.85); }
  .sl-domain svg {
    width: 36px;
    height: 36px;
    color: var(--gold-3);
    margin-bottom: 18px;
  }
  .sl-domain-t {
    font-family: var(--display);
    font-style: italic;
    font-size: 20px;
    color: var(--paper);
    margin: 0 0 10px;
  }
  .sl-domain-d {
    font-size: 12px;
    color: rgba(246,244,238,.6);
    line-height: 1.6;
    margin: 0;
  }

  /* ── CTA ─────────────────────────────────────────────────────── */
  .sl-cta {
    padding: 100px 40px;
    background: var(--paper);
    text-align: center;
  }
  .sl-cta-h2 {
    font-family: var(--display);
    font-style: italic;
    font-size: clamp(36px, 5vw, 56px);
    margin: 16px 0 20px;
  }
  .sl-cta-h2 em { font-style: normal; color: var(--gold-3); }
  .sl-cta-p { font-size: 17px; color: var(--ink-3); max-width: 540px; margin: 0 auto 40px; line-height: 1.7; }

  @media (max-width: 900px) {
    .sl-hero { grid-template-columns: 1fr; }
    .sl-hero-dark { padding: 100px 32px 60px; }
    .sl-hero-light { padding: 60px 32px; }
    .sl-steps { grid-template-columns: 1fr 1fr; }
    .sl-steps::before { display: none; }
    .sl-domains-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 600px) {
    .sl-steps, .sl-domains-grid { grid-template-columns: 1fr; }
  }
</style>

<!-- HERO SPLIT -->
<section class="sl-hero">
  <div class="sl-hero-dark">
    <div class="sl-hero-dark-inner">
      <p class="sl-kicker">— Outil I · Conseil juridique IA</p>
      <h1 class="sl-h1">Setlou</h1>
      <p class="sl-h1-sub">Votre conseiller en droit du travail sénégalais disponible 24 h/24</p>
      <p class="sl-avertissement">
        Setlou fournit des informations juridiques à titre indicatif. Pour toute situation contentieuse, consultez un avocat inscrit au Barreau du Sénégal.
      </p>
      <div class="sl-hero-btns">
        <a href="/connexion" class="btn btn-gold">Accéder à Setlou</a>
        <a href="/formules"  class="btn btn-ghost" style="border-color:rgba(246,244,238,.3);color:var(--paper)">Voir les formules</a>
      </div>
    </div>
  </div>
  <div class="sl-hero-light">
    <p class="sl-kicker">— 10 sources hiérarchisées</p>
    <h2 class="sl-sources-title">Base juridique exhaustive</h2>
    <ol class="sl-sources">
      <li>
        <span class="sl-src-num">1</span>
        <div><span class="sl-src-name">Code du Travail</span>Loi n° 97-17 du 1er décembre 1997 et décrets d'application</div>
      </li>
      <li>
        <span class="sl-src-num">2</span>
        <div><span class="sl-src-name">Conventions collectives nationales</span>11 CCN sectorielles indexées et à jour</div>
      </li>
      <li>
        <span class="sl-src-num">3</span>
        <div><span class="sl-src-name">Règlements intérieurs types</span>Modèles OHADA et sénégalais</div>
      </li>
      <li>
        <span class="sl-src-num">4</span>
        <div><span class="sl-src-name">Jurisprudence</span>Cours suprême, Cour d'appel de Dakar, TT</div>
      </li>
      <li>
        <span class="sl-src-num">5</span>
        <div><span class="sl-src-name">Circulaires MFPE</span>Ministère de la Fonction Publique et de l'Emploi</div>
      </li>
      <li>
        <span class="sl-src-num">6</span>
        <div><span class="sl-src-name">Réglementation IPRES / CSS</span>Cotisations, prestations, délais</div>
      </li>
      <li>
        <span class="sl-src-num">7</span>
        <div><span class="sl-src-name">Textes OHADA</span>Acte uniforme sur le droit du travail</div>
      </li>
      <li>
        <span class="sl-src-num">8</span>
        <div><span class="sl-src-name">Conventions OIT ratifiées</span>Sénégal partie à 39 conventions</div>
      </li>
      <li>
        <span class="sl-src-num">9</span>
        <div><span class="sl-src-name">Conventions bilatérales</span>Accords de main-d'œuvre internationaux</div>
      </li>
      <li>
        <span class="sl-src-num">10</span>
        <div><span class="sl-src-name">Doctrine & doctrine administrative</span>Avis et recommandations à jour au 22 oct. 2025</div>
      </li>
    </ol>
  </div>
</section>

<!-- PROCESSUS -->
<section class="sl-process">
  <div class="sl-process-inner">
    <div class="sl-process-head">
      <p class="sl-kicker">— Comment fonctionne Setlou</p>
      <h2 class="sl-process-h2">Quatre étapes vers votre <em>réponse</em></h2>
    </div>
    <div class="sl-steps">
      <div class="sl-step">
        <div class="sl-step-num">1</div>
        <h3 class="sl-step-t">Posez votre question</h3>
        <p class="sl-step-d">En langue naturelle, en français ou en wolof. Décrivez librement votre situation sans jargon juridique.</p>
      </div>
      <div class="sl-step">
        <div class="sl-step-num">2</div>
        <h3 class="sl-step-t">Analyse hiérarchique</h3>
        <p class="sl-step-d">Setlou applique le principe de faveur : il recherche dans les 10 sources la règle la plus protectrice pour le salarié.</p>
      </div>
      <div class="sl-step">
        <div class="sl-step-num">3</div>
        <h3 class="sl-step-t">Réponse structurée</h3>
        <p class="sl-step-d">Résumé simple d'abord — puis les détails juridiques avec références aux articles de loi pour approfondir.</p>
      </div>
      <div class="sl-step">
        <div class="sl-step-num">4</div>
        <h3 class="sl-step-t">Approfondissement</h3>
        <p class="sl-step-d">Posez des questions de suivi. Setlou mémorise le contexte de votre situation pour toute la session.</p>
      </div>
    </div>
  </div>
</section>

<!-- DOMAINES -->
<section class="sl-domains">
  <div class="sl-domains-inner">
    <div class="sl-domains-head">
      <div>
        <p class="sl-kicker" style="color:var(--gold-2)">— Domaines de compétence</p>
        <h2 class="sl-domains-h2">Ce que Setlou <em>maîtrise</em></h2>
      </div>
    </div>
    <div class="sl-domains-grid">
      <div class="sl-domain">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round">
          <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
        </svg>
        <h3 class="sl-domain-t">Contrats de travail</h3>
        <p class="sl-domain-d">CDI, CDD, contrats saisonniers, conditions de renouvellement et de rupture</p>
      </div>
      <div class="sl-domain">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round">
          <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
        <h3 class="sl-domain-t">Licenciement</h3>
        <p class="sl-domain-d">Procédure, motifs légaux, indemnités, délais de préavis, contestation</p>
      </div>
      <div class="sl-domain">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round">
          <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        <h3 class="sl-domain-t">Congés & absences</h3>
        <p class="sl-domain-d">Calcul des droits à congé, congé maladie, maternité, paternité, congés exceptionnels</p>
      </div>
      <div class="sl-domain">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round">
          <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>
        </svg>
        <h3 class="sl-domain-t">Salaires & primes</h3>
        <p class="sl-domain-d">SMIG, classifications, heures supplémentaires, primes obligatoires, 13e mois</p>
      </div>
      <div class="sl-domain">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round">
          <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
        </svg>
        <h3 class="sl-domain-t">Santé & sécurité</h3>
        <p class="sl-domain-d">Accidents du travail, maladies professionnelles, obligations de l'employeur, CSS</p>
      </div>
      <div class="sl-domain">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round">
          <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/>
        </svg>
        <h3 class="sl-domain-t">Représentation</h3>
        <p class="sl-domain-d">Délégués du personnel, syndicats, négociation collective, droit de grève</p>
      </div>
      <div class="sl-domain">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round">
          <circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/>
        </svg>
        <h3 class="sl-domain-t">IPRES & retraite</h3>
        <p class="sl-domain-d">Cotisations, régimes général et cadres, droits acquis, pension de retraite</p>
      </div>
      <div class="sl-domain">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round">
          <circle cx="12" cy="12" r="10"/>
          <line x1="2" y1="12" x2="22" y2="12"/>
          <path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/>
        </svg>
        <h3 class="sl-domain-t">Expatriés</h3>
        <p class="sl-domain-d">Permis de travail, conventions bilatérales, régimes de sécurité sociale applicables</p>
      </div>
    </div>
  </div>
</section>

<!-- CTA / OUTIL -->
{user ? (
  <section style="background:var(--paper);padding:80px 40px">
    <div style="max-width:900px;margin:0 auto">
      <p style="font-family:var(--sans);font-size:10px;letter-spacing:5px;text-transform:uppercase;color:var(--gold-3);margin-bottom:16px">— Conseiller juridique IA</p>
      <h2 style="font-family:var(--display);font-style:italic;font-size:clamp(32px,4vw,52px);color:var(--ink);margin:0 0 40px;line-height:1.1">
        Posez votre question <em style="color:var(--gold-3)">à Setlou</em>
      </h2>
      <AssistanceChat client:load assistantType="setlou" variant="full" />
    </div>
  </section>
) : (
  <section class="sl-cta">
    <p class="sl-kicker">— Formules d'accès</p>
    <h2 class="sl-cta-h2">Posez votre<br/>première <em>question</em></h2>
    <p class="sl-cta-p">Formule Basique : 3 questions/mois. Formule Silver et Gold : usage illimité avec historique complet. Base juridique à jour au 22 octobre 2025.</p>
    <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap">
      <a href="/connexion" class="btn btn-primary">Accéder à Setlou</a>
      <a href="/formules"  class="btn btn-ghost">Voir les formules</a>
    </div>
  </section>
)}

</Layout>
