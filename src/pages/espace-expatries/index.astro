---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import DashboardShell from '../../components/DashboardShell.astro';
import DashboardBanner from '../../components/dashboard/DashboardBanner.astro';
import DashboardHero from '../../components/dashboard/DashboardHero.astro';
import DashboardStats from '../../components/dashboard/DashboardStats.astro';
import QuickAccessGrid from '../../components/dashboard/QuickAccessGrid.astro';
import { createClient } from '../../lib/supabase';
import { SubscriptionService } from '../../lib/subscriptionService';
import { requireRole } from '../../lib/guards';

const guard = await requireRole(Astro, 'expatriate');
if (guard) return guard;

const { user } = Astro.locals;
const supabase = createClient({ request: Astro.request, cookies: Astro.cookies });
const subscriptionService = new SubscriptionService(supabase);

const activeSubscription = await subscriptionService.getUserSubscription(user.id);
const hasActiveSubscription = !!(activeSubscription && activeSubscription.status === 'active');
const planLabel = activeSubscription?.plan.display_name ?? null;

const { data: documentsData } = await supabase
  .from('documents')
  .select('id')
  .eq('owner_id', user.id);
const documentCount = documentsData?.length ?? 0;

const { data: profileData } = await supabase
  .from('profiles')
  .select('organization, phone, address, country, first_name, last_name')
  .eq('id', user.id)
  .single();

const firstName = profileData?.first_name ?? (user.user_metadata?.first_name as string | undefined) ?? '';
const lastName = profileData?.last_name ?? (user.user_metadata?.last_name as string | undefined) ?? '';
const country = profileData?.country ?? 'International';
---

<DashboardLayout title="Espace Expatriés - PREVICARE EMPLOI">
  <DashboardShell role="expatriate">

    <DashboardBanner
      hasSubscription={hasActiveSubscription}
      planLabel={planLabel}
      role="expatriate"
    />

    <DashboardHero
      title={`Bienvenue, ${firstName} ${lastName}`}
      subtitle="Votre espace expatrié PREVICARE EMPLOI"
      name={country !== 'International' ? `Basé(e) en : ${country}` : undefined}
    />

    <DashboardStats
      stats={[
        {
          label: 'Abonnement',
          value: hasActiveSubscription ? (planLabel ?? 'Actif') : 'Inactif',
          sublabel: hasActiveSubscription ? 'Protection active' : 'Souscription requise',
          icon: 'check',
          color: hasActiveSubscription ? 'green' : 'orange',
        },
        {
          label: 'Documents archivés',
          value: documentCount,
          sublabel: 'Documents sécurisés',
          icon: 'document',
          color: 'secondary',
        },
        {
          label: 'Pays de résidence',
          value: country,
          sublabel: 'Localisation actuelle',
          icon: 'globe',
          color: 'teal',
        },
        {
          label: 'Assistance SETLOU',
          value: 'Disponible',
          sublabel: 'Support IA inclus',
          icon: 'shield',
          color: 'blue',
        },
      ]}
    />

    <QuickAccessGrid
      items={[
        {
          title: 'Documents',
          description: 'Archivage sécurisé',
          href: '/espace-expatries/documents',
          icon: 'document',
        },
        {
          title: 'SETLOU',
          description: 'Conseil juridique digital',
          href: '/espace-expatries/juridique/setlou',
          icon: 'shield',
        },
        {
          title: 'Xalima',
          description: 'Rédaction de documents',
          href: '/espace-expatries/juridique/courriers',
          icon: 'edit',
        },
        {
          title: 'Jurithèque',
          description: 'Bibliothèque juridique',
          href: '/espace-expatries/juritheque',
          icon: 'book',
        },
        {
          title: 'Assistance',
          description: 'Support & tickets',
          href: '/espace-expatries/assistance',
          icon: 'support',
        },
        {
          title: 'Tickets',
          description: 'Suivi des demandes',
          href: '/espace-expatries/tickets',
          icon: 'message',
        },
      ]}
    />

    <!-- Démarches expatriés -->
    <div class="bg-white rounded-xl border mb-6" style="border-color:var(--rule)">
      <div class="p-5 border-b" style="border-color:var(--rule)">
        <h3 class="font-semibold text-base" style="color:var(--ink)">Démarches expatriés</h3>
        <p class="text-sm mt-0.5" style="color:var(--ink-4)">Gérez vos obligations administratives depuis n'importe où dans le monde</p>
      </div>
      <div class="p-5 grid md:grid-cols-2 gap-4">
        {[
          { title: 'Attestations officielles', desc: 'Demandez vos attestations de travail, de salaire et certificats officiels.', cta: null, icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z' },
          { title: 'Droits sociaux', desc: 'Consultez et gérez vos droits acquis au Sénégal (retraite, protection sociale).', cta: null, icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' },
          { title: 'Mise à jour du dossier', desc: 'Mettez à jour vos informations personnelles et votre adresse à l\'étranger.', cta: '/espace-expatries/parametres', icon: 'M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4' },
          { title: 'Permis de travail', desc: 'Régularisez ou renouvelez votre permis de travail à l\'étranger.', cta: null, icon: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z' },
        ].map((item) => (
          <div class="rounded-xl border p-4" style={`border-color:var(--rule);opacity:${item.cta ? '1' : '0.75'}`}>
            <div class="flex items-center justify-between mb-3">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0" style="background:rgba(201,169,97,.10)">
                  <svg class="h-4 w-4" style="color:var(--gold-3)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d={item.icon} />
                  </svg>
                </div>
                <h4 class="font-semibold text-sm" style="color:var(--ink)">{item.title}</h4>
              </div>
              {item.cta ? (
                <a href={item.cta} class="text-xs font-semibold px-2.5 py-1 rounded-lg transition-opacity hover:opacity-80" style="background:rgba(201,169,97,.15);color:var(--gold-3)">Accéder</a>
              ) : (
                <span class="text-[10px] font-medium px-2 py-0.5 rounded" style="background:rgba(11,29,58,.06);color:var(--ink-4)">À venir</span>
              )}
            </div>
            <p class="text-sm" style="color:var(--ink-4)">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>

  </DashboardShell>
</DashboardLayout>
