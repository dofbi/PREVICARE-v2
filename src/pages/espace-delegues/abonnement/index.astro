---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import DashboardShell from '../../../components/DashboardShell.astro';
import { createClient } from '../../../lib/supabase';
import { SubscriptionService } from '../../../lib/subscriptionService';
import { formatCurrency, PAYMENT_METHODS, PAYMENT_STATUS_LABELS } from '../../../types/payments';
import { STATUS_LABELS } from '../../../types/subscription';
import { requireRole } from '../../../lib/guards';

const guard = await requireRole(Astro, 'delegate');
if (guard) return guard;

const { user } = Astro.locals;
const supabase = createClient({ request: Astro.request, cookies: Astro.cookies });
const subscriptionService = new SubscriptionService(supabase);

const subscription = await subscriptionService.getUserSubscription(user.id);
const payments = await subscriptionService.getUserPayments(user.id);

const { data: pendingSubs } = await supabase
  .from('subscriptions')
  .select('id, status, plan_id, payment_reference, plan:subscription_plans(display_name, price)')
  .eq('user_id', user.id)
  .eq('status', 'pending')
  .order('created_at', { ascending: false });

const todayStr = new Date().toISOString().slice(0, 10);

function formatDate(dateString: string | null): string {
  if (!dateString) return '-';
  return new Date(dateString).toLocaleDateString('fr-FR', { day: '2-digit', month: 'long', year: 'numeric' });
}

function isToday(dateString: string | null): boolean {
  if (!dateString) return false;
  return dateString.slice(0, 10) === todayStr;
}

function getSubscriptionId(payment: Record<string, unknown>): string | null {
  if (payment.subscription_id && typeof payment.subscription_id === 'string') return payment.subscription_id;
  const sub = payment.subscription as Record<string, unknown> | null;
  if (sub?.id && typeof sub.id === 'string') return sub.id;
  return null;
}
---

<DashboardLayout title="Mon Abonnement - PREVICARE EMPLOI">
  <DashboardShell role="delegate">

    <nav class="flex mb-6" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 text-sm" style="color:var(--ink-4)">
        <li><a href="/espace-delegues" class="hover:opacity-80 transition-opacity" style="color:var(--ink-4)">Tableau de bord</a></li>
        <li><span>/</span></li>
        <li class="font-medium" style="color:var(--ink)">Mon Abonnement</li>
      </ol>
    </nav>

    <div class="space-y-8">

      {pendingSubs && pendingSubs.length > 0 && !subscription && (
        <div class="p-5 rounded-xl border flex items-start gap-3" style="background:rgba(201,169,97,.08);border-color:rgba(201,169,97,.30)">
          <svg class="h-5 w-5 shrink-0 mt-0.5" style="color:var(--gold-3)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <div class="flex-1">
            <p class="font-semibold text-sm" style="color:var(--ink)">Paiement en attente de confirmation</p>
            <p class="text-sm mt-1" style="color:var(--ink-4)">Un paiement est en cours de traitement. Si vous avez déjà effectué le paiement, cliquez sur <strong>Relancer</strong> pour vérifier et activer votre abonnement.</p>
            <div class="mt-3 flex flex-wrap gap-2">
              {pendingSubs.map((ps) => {
                const planData = Array.isArray(ps.plan) ? ps.plan[0] : ps.plan;
                return (
                  <button data-relancer data-subscription-id={ps.id} class="inline-flex items-center gap-2 px-4 py-2 text-sm font-semibold rounded-lg transition-opacity hover:opacity-90" style="background:var(--ink);color:var(--gold)">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                    Relancer — {planData?.display_name ?? 'Abonnement'}
                  </button>
                );
              })}
            </div>
          </div>
        </div>
      )}

      {subscription ? (
        <div class="bg-white rounded-xl border overflow-hidden" style="border-color:var(--rule)">
          <div class="relative px-6 py-6" style="background:var(--ink)">
            <div class="absolute left-0 top-0 bottom-0 w-1" style="background:var(--gold)"></div>
            <div class="flex items-center justify-between">
              <div>
                <p class="text-xs uppercase tracking-wider" style="color:rgba(255,255,255,.55)">Votre formule actuelle</p>
                <h2 class="text-2xl font-bold mt-1" style="font-family:var(--display);color:#fff">{subscription.plan?.display_name || 'Plan'}</h2>
              </div>
              <span class={`inline-flex items-center px-3 py-1 rounded-full text-sm font-medium ${STATUS_LABELS[subscription.status]?.color || 'bg-gray-100 text-gray-800'}`}>
                {STATUS_LABELS[subscription.status]?.label || subscription.status}
              </span>
            </div>
          </div>
          <div class="p-6">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
              <div>
                <p class="text-xs font-semibold uppercase tracking-wider" style="color:var(--ink-4)">Numéro de contrat</p>
                <p class="font-semibold text-lg mt-1" style="color:var(--ink)">{subscription.contract_number || '-'}</p>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-wider" style="color:var(--ink-4)">Date de début</p>
                <p class="font-semibold mt-1" style="color:var(--ink)">{formatDate(subscription.starts_at)}</p>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-wider" style="color:var(--ink-4)">Date d'expiration</p>
                <p class="font-semibold mt-1" style="color:var(--ink)">{formatDate(subscription.expires_at)}</p>
              </div>
            </div>
            {subscription.plan?.features && (
              <div class="mt-6 pt-6 border-t" style="border-color:var(--rule)">
                <h3 class="font-semibold mb-3" style="color:var(--ink)">Avantages inclus</h3>
                <ul class="grid grid-cols-1 md:grid-cols-2 gap-2">
                  {subscription.plan.features.map((feature: string) => (
                    <li class="flex items-center gap-2 text-sm" style="color:var(--ink-4)">
                      <svg class="h-4 w-4 flex-shrink-0" style="color:#16a34a" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                      {feature}
                    </li>
                  ))}
                </ul>
              </div>
            )}
            <div class="mt-6 pt-6 border-t flex flex-wrap gap-4" style="border-color:var(--rule)">
              <a href={`/api/generate-contract?subscriptionId=${subscription.id}`} class="inline-flex items-center gap-2 px-4 py-2 text-sm font-semibold rounded-lg transition-opacity hover:opacity-90" style="background:var(--ink);color:var(--gold)">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                Télécharger mon contrat
              </a>
              <a href="/formules" class="inline-flex items-center px-4 py-2 text-sm font-semibold rounded-lg border transition-opacity hover:opacity-80" style="border-color:var(--rule);color:var(--ink)">Changer de formule</a>
            </div>
          </div>
        </div>
      ) : (
        <div class="bg-white rounded-xl border p-10 text-center" style="border-color:var(--rule)">
          <div class="mx-auto w-16 h-16 rounded-full flex items-center justify-center mb-4" style="background:rgba(201,169,97,.08)">
            <svg class="h-8 w-8" style="color:var(--gold-3)" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          </div>
          <h3 class="font-semibold mb-2" style="color:var(--ink)">Aucun abonnement actif</h3>
          <p class="text-sm mb-6" style="color:var(--ink-4)">Souscrivez à une formule pour accéder à tous les avantages PREVICARE.</p>
          <a href="/espace-delegues/abonnement/souscrire?plan=delegate" class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold rounded-lg transition-opacity hover:opacity-90" style="background:var(--ink);color:var(--gold)">Souscrire à l'offre Délégués</a>
        </div>
      )}

      <div class="bg-white rounded-xl border" style="border-color:var(--rule)">
        <div class="px-6 py-4 border-b" style="border-color:var(--rule)">
          <h3 class="font-semibold" style="color:var(--ink)">Historique des paiements</h3>
        </div>
        {payments.length > 0 ? (
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead>
                <tr style="background:rgba(11,29,58,.03)">
                  <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color:var(--ink-4)">Facture</th>
                  <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color:var(--ink-4)">Date</th>
                  <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color:var(--ink-4)">Montant</th>
                  <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color:var(--ink-4)">Méthode</th>
                  <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color:var(--ink-4)">Statut</th>
                  <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider" style="color:var(--ink-4)">Actions</th>
                </tr>
              </thead>
              <tbody>
                {payments.map((payment: any) => {
                  const isPendingToday = payment.status === 'pending' && payment.payment_method === 'dexchange' && isToday(payment.created_at as string | null);
                  const subId = getSubscriptionId(payment);
                  const paymentStatus: string = payment.status;
                  const paymentMethod: string = payment.payment_method;
                  return (
                    <tr class="border-t transition-colors hover:bg-[rgba(11,29,58,.02)]" style="border-color:var(--rule)">
                      <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold" style="color:var(--ink)">{(payment.invoice_number as string) || '-'}</td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm" style="color:var(--ink-4)">{formatDate(payment.created_at as string | null)}</td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold" style="color:var(--ink)">{formatCurrency(payment.amount as number)}</td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm" style="color:var(--ink-4)">{PAYMENT_METHODS[paymentMethod as keyof typeof PAYMENT_METHODS]?.icon || ''}{' '}{PAYMENT_METHODS[paymentMethod as keyof typeof PAYMENT_METHODS]?.label || paymentMethod}</td>
                      <td class="px-6 py-4 whitespace-nowrap">
                        <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${PAYMENT_STATUS_LABELS[paymentStatus as keyof typeof PAYMENT_STATUS_LABELS]?.color || 'bg-gray-100 text-gray-800'}`}>
                          {PAYMENT_STATUS_LABELS[paymentStatus as keyof typeof PAYMENT_STATUS_LABELS]?.label || paymentStatus}
                        </span>
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm">
                        <div class="flex items-center gap-3">
                          {paymentStatus === 'completed' && (<a href={`/api/generate-invoice?paymentId=${payment.id as string}`} class="text-xs font-semibold" style="color:var(--gold-3)">Télécharger</a>)}
                          {isPendingToday && subId && (<button data-relancer data-subscription-id={subId} class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold rounded-lg" style="background:var(--ink);color:var(--gold)"><svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>Relancer</button>)}
                          {!isPendingToday && paymentStatus !== 'completed' && (<span style="color:var(--ink-4)" class="text-xs">—</span>)}
                        </div>
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        ) : (
          <div class="p-8 text-center"><p class="text-sm" style="color:var(--ink-4)">Aucun paiement enregistré</p></div>
        )}
      </div>
    </div>

    <div id="relancerOverlay" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center">
      <div class="bg-white rounded-xl p-6 max-w-sm w-full mx-4 text-center shadow-xl border" style="border-color:var(--rule)">
        <div class="animate-spin mx-auto h-10 w-10 border-4 rounded-full mb-4" style="border-color:var(--rule);border-top-color:var(--ink)"></div>
        <p class="font-semibold" style="color:var(--ink)" id="relancerMsg">Vérification du paiement...</p>
        <p class="text-sm mt-1" style="color:var(--ink-4)">Veuillez patienter</p>
      </div>
    </div>
  </DashboardShell>
</DashboardLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const overlay = document.getElementById('relancerOverlay');
    const relancerMsg = document.getElementById('relancerMsg');
    document.querySelectorAll('[data-relancer]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const subscriptionId = (btn as HTMLElement).dataset.subscriptionId;
        if (!subscriptionId) return;
        if (overlay) overlay.classList.remove('hidden');
        if (relancerMsg) relancerMsg.textContent = 'Vérification du paiement...';
        try {
          const response = await fetch('/api/payment/relancer', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ subscriptionId }) });
          const text = await response.text();
          let result: { success: boolean; alreadyActive?: boolean; alreadyPaid?: boolean; paymentUrl?: string; redirect?: string; message?: string; };
          try { result = JSON.parse(text); } catch { if (overlay) overlay.classList.add('hidden'); alert('Le serveur est temporairement indisponible.'); return; }
          if (!result.success) { if (overlay) overlay.classList.add('hidden'); alert(result.message || 'Une erreur est survenue'); return; }
          if (result.alreadyActive || result.redirect) { if (relancerMsg) relancerMsg.textContent = 'Abonnement activé !'; setTimeout(() => { window.location.href = result.redirect || '/espace-delegues/abonnement'; }, 800); return; }
          if (result.alreadyPaid) { if (relancerMsg) relancerMsg.textContent = 'Paiement confirmé, activation en cours...'; setTimeout(() => { window.location.href = result.redirect || '/espace-delegues/abonnement'; }, 800); return; }
          if (result.paymentUrl) { if (relancerMsg) relancerMsg.textContent = 'Redirection vers le paiement...'; setTimeout(() => { window.location.href = result.paymentUrl!; }, 400); return; }
          if (overlay) overlay.classList.add('hidden'); alert('Réponse inattendue, veuillez réessayer.');
        } catch (error: unknown) { if (overlay) overlay.classList.add('hidden'); alert(error instanceof Error ? error.message : 'Une erreur réseau est survenue'); }
      });
    });
  });
</script>
