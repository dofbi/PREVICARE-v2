---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import DashboardShell from '../../../components/DashboardShell.astro';
import { createClient, createServiceRoleClient } from '../../../lib/supabase';
import { getTransactionStatus } from '../../../lib/dexchangeService';

const ref = Astro.url.searchParams.get('ref');

if (ref) {
  try {
    const serviceSupabase = createServiceRoleClient();

    const { data: sub } = await serviceSupabase
      .from('subscriptions')
      .select('id, status, payment_reference, user_id')
      .eq('id', ref)
      .single();

    if (sub && sub.status === 'pending' && sub.payment_reference) {
      const statusResponse = await getTransactionStatus(sub.payment_reference);
      const dexStatus = statusResponse.transaction.Status;

      if (dexStatus === 'SUCCESS') {
        await serviceSupabase
          .from('subscriptions')
          .update({ status: 'cancelled', updated_at: new Date().toISOString() })
          .eq('user_id', sub.user_id)
          .eq('status', 'active')
          .neq('id', ref);

        await serviceSupabase
          .from('subscriptions')
          .update({ status: 'active', updated_at: new Date().toISOString() })
          .eq('id', ref);

        await serviceSupabase
          .from('payments')
          .update({ status: 'completed' })
          .eq('subscription_id', ref)
          .eq('status', 'pending');
      }
    }
  } catch (err) {
    console.error('[Succes page] Dexchange verification error:', err);
  }
}

const { user } = Astro.locals;

if (!user) {
  return Astro.redirect('/connexion');
}

const supabase = createClient({ request: Astro.request, cookies: Astro.cookies });

let subscriptionStatus: string | null = null;
let planName: string | null = null;

if (ref) {
  const { data: subscription, error } = await supabase
    .from('subscriptions')
    .select('status, plan:subscription_plans(display_name)')
    .eq('id', ref)
    .eq('user_id', user.id)
    .single();

  if (!error && subscription) {
    subscriptionStatus = subscription.status;
    const planData = subscription.plan;
    if (planData && typeof planData === 'object' && !Array.isArray(planData)) {
      planName = (planData as { display_name: string }).display_name;
    } else if (Array.isArray(planData) && planData.length > 0) {
      planName = (planData[0] as { display_name: string }).display_name;
    }
  }
}

const isActive = subscriptionStatus === 'active';
---

<DashboardLayout title="Paiement confirmé - PREVICARE EMPLOI">
  <DashboardShell role="delegate">
    <div class="max-w-2xl mx-auto text-center py-12">
      {isActive ? (
        <div>
          <div class="mx-auto w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mb-6">
            <svg class="h-10 w-10 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-gray-900 mb-3">Abonnement activé !</h2>
          <p class="text-gray-600 mb-2">
            Votre paiement a bien été reçu. Votre abonnement
            {planName && <strong> {planName}</strong>} est maintenant actif.
          </p>
          <p class="text-sm text-gray-500 mb-8">Vous avez désormais accès à tous les services inclus dans votre formule.</p>
          <a href="/espace-delegues/abonnement" class="inline-flex items-center px-6 py-3 bg-primary text-white rounded-lg hover:bg-primary/90 transition-colors font-medium">
            Voir mon abonnement
          </a>
        </div>
      ) : (
        <div>
          <div class="mx-auto w-20 h-20 bg-yellow-100 rounded-full flex items-center justify-center mb-6">
            <svg class="h-10 w-10 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-gray-900 mb-3">Paiement en cours de vérification</h2>
          <p class="text-gray-600 mb-2">Votre paiement est en cours de traitement. Votre abonnement sera activé dans quelques instants.</p>
          <p class="text-sm text-gray-500 mb-8">Si votre abonnement n'est pas activé dans 5 minutes, contactez notre support.</p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/espace-delegues/abonnement" class="inline-flex items-center justify-center px-6 py-3 bg-primary text-white rounded-lg hover:bg-primary/90 transition-colors font-medium">
              Mon abonnement
            </a>
            <a href="/espace-delegues/assistance" class="inline-flex items-center justify-center px-6 py-3 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors font-medium">
              Contacter le support
            </a>
          </div>
        </div>
      )}
    </div>
  </DashboardShell>
</DashboardLayout>
