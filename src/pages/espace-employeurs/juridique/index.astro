---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import DashboardShell from '../../../components/DashboardShell.astro';
import { requireRole } from '../../../lib/guards';

const guard = await requireRole(Astro, 'employer');
if (guard) return guard;
---

<DashboardLayout title="Juridique & RH - PREVICARE EMPLOI">
  <DashboardShell role="employer">

    <nav class="flex mb-6" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 text-sm" style="color:var(--ink-4)">
        <li><a href="/espace-employeurs" class="hover:opacity-80 transition-opacity" style="color:var(--ink-4)">Tableau de bord</a></li>
        <li><span>/</span></li>
        <li class="font-medium" style="color:var(--ink)">Juridique & RH</li>
      </ol>
    </nav>

    <div class="mb-8">
      <h1 class="text-2xl font-bold" style="font-family:var(--display);color:var(--ink)">Outils Juridiques & RH</h1>
      <p class="text-sm mt-1" style="color:var(--ink-4)">Accédez à vos outils de conformité RH et de gestion juridique</p>
    </div>

    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">

      <!-- SETLOU -->
      <a href="/espace-employeurs/juridique/setlou"
        class="block bg-white rounded-xl border hover:shadow-md transition-shadow p-6"
        style="border-color:var(--rule);border-left:4px solid var(--ink)">
        <div class="flex items-start gap-4">
          <div class="h-10 w-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background:rgba(201,169,97,.12)">
            <svg class="h-5 w-5" style="color:var(--gold-3)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <div>
            <div class="flex items-center gap-2 mb-0.5">
              <h4 class="font-semibold" style="color:var(--ink)">SETLOU</h4>
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium" style="background:rgba(201,169,97,.12);color:var(--gold-3)">
                <span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span>IA disponible
              </span>
            </div>
            <p class="text-xs" style="color:var(--ink-4)">Consultant RH digital</p>
          </div>
        </div>
        <p class="text-sm mt-4 leading-relaxed" style="color:var(--ink-4)">Posez vos questions sur vos obligations RH, les procédures disciplinaires et le droit du travail sénégalais.</p>
        <p class="text-xs font-semibold mt-3" style="color:var(--gold-3)">Consulter SETLOU →</p>
      </a>

      <!-- Xalima -->
      <a href="/espace-employeurs/juridique/courriers"
        class="block bg-white rounded-xl border hover:shadow-md transition-shadow p-6"
        style="border-color:var(--rule);border-left:4px solid var(--gold)">
        <div class="flex items-start gap-4">
          <div class="h-10 w-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background:rgba(201,169,97,.12)">
            <svg class="h-5 w-5" style="color:var(--gold-3)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
            </svg>
          </div>
          <div>
            <div class="flex items-center gap-2 mb-0.5">
              <h4 class="font-semibold" style="color:var(--ink)">Xalima</h4>
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium" style="background:rgba(201,169,97,.12);color:var(--gold-3)">
                <span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span>IA disponible
              </span>
            </div>
            <p class="text-xs" style="color:var(--ink-4)">Rédaction documents RH</p>
          </div>
        </div>
        <p class="text-sm mt-4 leading-relaxed" style="color:var(--ink-4)">Générez des documents RH professionnels : convocations, notifications de sanction, lettres de licenciement, attestations…</p>
        <p class="text-xs font-semibold mt-3" style="color:var(--gold-3)">Rédiger un document →</p>
      </a>

      <!-- Jurithèque -->
      <a href="/espace-employeurs/juritheque"
        class="block bg-white rounded-xl border hover:shadow-md transition-shadow p-6"
        style="border-color:var(--rule)">
        <div class="flex items-start gap-4">
          <div class="h-10 w-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background:rgba(201,169,97,.12)">
            <svg class="h-5 w-5" style="color:var(--gold-3)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
            </svg>
          </div>
          <div>
            <h4 class="font-semibold" style="color:var(--ink)">Jurithèque</h4>
            <p class="text-xs mt-0.5" style="color:var(--ink-4)">Bibliothèque de textes juridiques</p>
          </div>
        </div>
        <p class="text-sm mt-4 leading-relaxed" style="color:var(--ink-4)">Consultez le Code du Travail, les Conventions Collectives et les textes réglementaires sénégalais.</p>
      </a>

      <!-- Conformité RH -->
      <div class="bg-white rounded-xl border p-6" style="border-color:var(--rule)">
        <div class="flex items-start gap-4">
          <div class="h-10 w-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background:rgba(22,163,74,.10)">
            <svg class="h-5 w-5" style="color:#16a34a" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <div>
            <h4 class="font-semibold" style="color:var(--ink)">Conformité RH</h4>
            <p class="text-xs mt-0.5" style="color:var(--ink-4)">Obligations légales</p>
          </div>
        </div>
        <p class="text-sm mt-4 leading-relaxed" style="color:var(--ink-4)">Vérifiez votre conformité avec les obligations du Code du Travail sénégalais : déclarations sociales, procédures disciplinaires, obligations d'affichage.</p>
        <div class="mt-4">
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold" style="background:rgba(22,163,74,.10);color:#15803d">
            Code du Travail — Loi n° 97-17
          </span>
        </div>
      </div>

      <!-- Suivi des dossiers -->
      <div class="bg-white rounded-xl border p-6" style="border-color:var(--rule)">
        <div class="flex items-start gap-4">
          <div class="h-10 w-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background:rgba(201,169,97,.12)">
            <svg class="h-5 w-5" style="color:var(--gold-3)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
            </svg>
          </div>
          <div>
            <h4 class="font-semibold" style="color:var(--ink)">Suivi des dossiers</h4>
            <p class="text-xs mt-0.5" style="color:var(--ink-4)">Procédures en cours</p>
          </div>
        </div>
        <p class="text-sm mt-4 leading-relaxed" style="color:var(--ink-4)">Suivez l'état de vos dossiers disciplinaires, procédures de licenciement et litiges en cours.</p>
        <a href="/espace-employeurs/tickets" class="block text-xs font-semibold mt-3" style="color:var(--gold-3)">Voir mes tickets →</a>
      </div>

      <!-- Consultation juridique -->
      <a href="/espace-employeurs/juridique/consultation"
        class="block bg-white rounded-xl border hover:shadow-md transition-shadow p-6"
        style="border-color:var(--rule)">
        <div class="flex items-start gap-4">
          <div class="h-10 w-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background:rgba(201,169,97,.12)">
            <svg class="h-5 w-5" style="color:var(--gold-3)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <div>
            <h4 class="font-semibold" style="color:var(--ink)">Consultation juridique</h4>
            <p class="text-xs mt-0.5" style="color:var(--ink-4)">Conseils personnalisés</p>
          </div>
        </div>
        <p class="text-sm mt-4 leading-relaxed" style="color:var(--ink-4)">Obtenez des conseils juridiques pour vos problématiques RH et de gestion du personnel.</p>
        <p class="text-xs font-semibold mt-3" style="color:var(--gold-3)">Prendre rendez-vous →</p>
      </a>
    </div>
  </DashboardShell>
</DashboardLayout>
